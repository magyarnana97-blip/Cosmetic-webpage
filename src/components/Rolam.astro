---
// RÓLAM szekció — Marianna bemutatása
---

<section class="rolam" id="rolam">
  <div class="rolam-head">
    <div class="rolam-text">
      <span class="eyebrow">Rólam</span>
      <h2 class="rolam-h2">A bőr állapota <em>információ.</em><br/>A kezelés célja ennek <em>megértése.</em></h2>
      <p class="rolam-sub">Több mint kezeléseket kínálok. A célom megérteni, mire van valóban szüksége a bőrödnek, és olyan megoldást találni, amely hosszú távon is támogatja annak egészségét és természetes ragyogását.</p>
    </div>
    <div class="rolam-photo">
      <img src="/marianna-rolam.webp?3" alt="Marianna portré" />
    </div>
  </div>
</section>

<style>
  .rolam{
    background: var(--bg);
    padding: 26px 1.1rem 37px 24px;
    overflow: hidden;
    position: relative;
  }

  /* Felso feher fedoreteg */
  .rolam::before{
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 80px;
    background: linear-gradient(to bottom, var(--bg) 0%, var(--bg) 35%, transparent 100%);
    z-index: 3;
    pointer-events: none;
  }

  /* Jobb oldali fedoreteg */
  .rolam::after{
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 60px;
    background: linear-gradient(to left, var(--bg) 0%, transparent 100%);
    z-index: 3;
    pointer-events: none;
  }

  .rolam-head{
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    min-height: 506px;
  }

  .rolam-text{
    position: relative;
    z-index: 4;
    max-width: 207px;
  }

  .rolam .eyebrow{ font-size: .525rem; margin-bottom: 12px; display: block; }
  .rolam-h2{ font-size: 25px; line-height: 1.12; margin: 0 0 11px; }
  .rolam-h2 em{ font-style: italic; color: var(--green); }
  .rolam-sub{ color: var(--muted); font-size: 10px; line-height: 1.55; max-width: 170px; }

  .rolam-photo{
    position: absolute;
    top: -101px;
    right: 0px;
    width: 69%;
    z-index: 1;
    overflow: hidden;
  }

  .rolam-photo img{
    width: 100%;
    height: auto;
    display: block;
    /* Fehér háttér eltűnik, a zöldes oldal átszűrődik — természetes beolvasztás */
    mix-blend-mode: multiply;
    /* Finom mélység — nem "odarakott" hatás */
    filter: drop-shadow(-6px 8px 20px rgba(60,80,40,0.18));
  }
</style>
