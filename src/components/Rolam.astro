---
// RÓLAM szekció — Marianna bemutatása
---

<section class="rolam" id="rolam">
  <div class="rolam-head">
    <div class="rolam-text">
      <span class="eyebrow">Rólam</span>
      <h2 class="rolam-h2">A bőr állapota <em>információ.</em><br/>A kezelés célja ennek <em>megértése.</em></h2>
      <p class="rolam-sub">Több mint kezeléseket kínálok. A célom megérteni, mire van valóban szüksége a bőrödnek, és olyan megoldást találni, amely hosszú távon is támogatja annak egészségét és természetes ragyogását.</p>
    </div>
    <div class="rolam-photo">
      <img src="/marianna-rolam.webp?3" alt="Marianna portré" />
    </div>
  </div>
</section>

<style>
  .rolam{
    background: var(--bg);
    padding: 26px 1.1rem 37px 24px;
    overflow: hidden;
  }

  .rolam-head{
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    min-height: 506px;
  }

  .rolam-text{
    position: relative;
    z-index: 2;
    max-width: 207px;
  }

  .rolam .eyebrow{
    font-size: .525rem;
    margin-bottom: 12px;
    display: block;
  }

  .rolam-h2{
    font-size: 25px;
    line-height: 1.12;
    margin: 0 0 11px;
  }

  .rolam-h2 em{ font-style: italic; color: var(--green); }

  .rolam-sub{
    color: var(--muted);
    font-size: 10px;
    line-height: 1.55;
    max-width: 170px;
  }

  /* top:0 = kep teteje a 'Rolam' szoval egyvonalban */
  .rolam-photo{
    position: absolute;
    top: 0px;
    right: 0px;
    width: 69%;
    z-index: 1;
    overflow: hidden;
  }

  .rolam-photo img{
    width: 100%;
    height: auto;
    display: block;
    /* Felul: elso 8%-ban teljesen atlatszо, 8-18% kozott halvany -> erosebb felso vages
       Jobb oldal + also sarok: radialis gradienssel elmaszatolva
       A ket reteg intersect-tel kombinalva */
    -webkit-mask-image:
      linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.3) 8%, #000 20%),
      linear-gradient(to left, transparent 0%, rgba(0,0,0,0.4) 10%, #000 25%),
      radial-gradient(75% 85% at 42% 52%, #000 52%, transparent 90%);
    -webkit-mask-composite: source-in, source-in;
    mask-image:
      linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.3) 8%, #000 20%),
      linear-gradient(to left, transparent 0%, rgba(0,0,0,0.4) 10%, #000 25%),
      radial-gradient(75% 85% at 42% 52%, #000 52%, transparent 90%);
    mask-composite: intersect, intersect;
  }

  @media (min-width: 760px){
    .rolam{ padding: 3rem 1.4rem; }
    .rolam-head{ min-height: 420px; }
    .rolam-h2{ font-size: 2rem; }
    .rolam-sub{ font-size: .9rem; max-width: 430px; }
    .rolam-text{ max-width: 480px; }
  }
</style>
