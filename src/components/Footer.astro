---
import type { T } from '../i18n/v3/hu';
const { tr } = Astro.props as { tr: T };
---
<footer class="foot">
  <div class="foot-inner">
    <span class="foot-name">
      <b>{tr.footer.brandBold}</b>{tr.footer.brandRest}
    </span>
    <span class="foot-tag">{tr.footer.tagline}</span>
    <span class="foot-copy">{tr.footer.copy}</span>
  </div>
</footer>
<style>
  .foot{background:var(--ink);padding:2rem var(--page-margin);}
  .foot-inner{max-width:1000px;margin:0 auto;display:flex;flex-direction:column;align-items:center;gap:.4rem;text-align:center;}
  .foot-name{font-family:var(--sans);font-size:1.05rem;color:var(--muted);letter-spacing:.01em;}
  .foot-name b{font-weight:700;color:rgba(255,255,255,.55);}
  .foot-tag{font-family:var(--serif);font-style:italic;color:var(--muted);font-size:.9rem;margin:.5rem 0 1.2rem;}
  .foot-copy{font-size:var(--section-label);color:var(--muted);opacity:.7;}
</style>
