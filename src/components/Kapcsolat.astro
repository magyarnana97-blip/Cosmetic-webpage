---
import type { T } from '../i18n/v3/hu';
const { tr } = Astro.props as { tr: T };
const ct = tr.contact;
---

<section class="kapcsolat" id="kapcsolat">
  <div class="kapcsolat-grid">
    <div class="kapcsolat-info">
      <span class="eyebrow">{ct.eyebrow}</span>
      <h2 class="kapcsolat-h2">{ct.h2}</h2>
      <p class="kapcsolat-sub">{ct.sub}</p>
      <ul class="kapcsolat-list">
        {ct.items.map(item => (
          <li class="kapcsolat-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d={item.icon} stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{item.label}</span>
          </li>
        ))}
      </ul>
    </div>
    <form class="kapcsolat-form" novalidate>
      {ct.fields.map(f => (
        <div class="form-field">
          <label for={f.id}>{f.label}</label>
          {f.type === 'textarea'
            ? <textarea id={f.id} name={f.id} rows={4} placeholder={f.placeholder} required={f.required}></textarea>
            : <input type={f.type} id={f.id} name={f.id} placeholder={f.placeholder} required={f.required} />}
        </div>
      ))}
      <div class="btn-wrap">
        <button type="submit" class="btn-cut">
          <span class="lbl">{ct.submit}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </button>
      </div>
    </form>
  </div>
</section>

<style>
  .kapcsolat{background:var(--bg);padding:2rem var(--page-margin) 3rem;}
  .kapcsolat-grid{max-width:1000px;margin:0 auto;display:grid;gap:2rem;}
  .kapcsolat-h2{font-family:var(--serif);font-size:var(--section-h2);font-weight:400;line-height:1.08;margin:.4rem 0 0;color:var(--ink);}
  .kapcsolat-sub{color:var(--muted);font-family:var(--sans);font-size:var(--section-sub);font-weight:300;line-height:1.65;margin-bottom:1.4rem;}
  .kapcsolat-item{display:flex;align-items:flex-start;gap:.6rem;font-family:var(--sans);font-size:var(--section-body);font-weight:300;color:var(--muted);}
  .kapcsolat-list{display:flex;flex-direction:column;gap:.55rem;margin-bottom:1.4rem;}
  .form-field{display:flex;flex-direction:column;gap:.35rem;font-family:var(--sans);font-size:.6rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
  .kapcsolat-form{display:flex;flex-direction:column;gap:1.1rem;}
  .kapcsolat-form input,.kapcsolat-form textarea{width:100%;padding:.7rem 0;border:none;border-bottom:1.5px solid rgba(58,63,62,.18);background:transparent;font-family:var(--sans);font-size:var(--section-body);font-weight:300;color:var(--ink);outline:none;transition:border-color .2s;}
  .kapcsolat-form input:focus,.kapcsolat-form textarea:focus{border-bottom-color:var(--green);}
  .kapcsolat-form textarea{resize:vertical;min-height:90px;}
  .btn-wrap{margin-top:.4rem;}
  /* btn-cut: csak a conic-gradient keret, belül átlátszó (bg szín) */
  .btn-cut{display:inline-flex;padding:0;background:conic-gradient(from 200deg at 50% 50%,rgba(168,201,106,0.12) 0%,rgba(168,201,106,0.5) 20%,#A8C96A 40%,#8FAE52 50%,#A8C96A 60%,rgba(168,201,106,0.4) 80%,rgba(168,201,106,0.12) 100%);clip-path:polygon(9px 0,100% 0,100% calc(100% - 9px),calc(100% - 9px) 100%,0 100%,0 9px);border:none;cursor:pointer;transition:.3s;}
  .btn-cut .lbl{display:inline-flex;align-items:center;gap:.45rem;white-space:nowrap;margin:1.5px;background:var(--bg);clip-path:polygon(8px 0,100% 0,100% calc(100% - 8px),calc(100% - 8px) 100%,0 100%,0 8px);color:var(--ink);font-family:var(--sans);font-size:.6rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:.75rem .95rem;transition:.3s;}
  .btn-cut:hover .lbl{background:var(--green);color:#fff;}
  @media (min-width:760px){.kapcsolat-grid{grid-template-columns:1fr 1.2fr;gap:4rem;align-items:start;}}
</style>
