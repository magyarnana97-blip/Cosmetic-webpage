---
// ░ KAPCSOLAT szekció — v3 dizájnban ░
---

<section class="kapcsolat-sec" id="kapcsolat">
  <div class="kapcsolat-grid">
    <div class="kapcsolat-info">
      <span class="eyebrow">Kapcsolat</span>
      <h2 class="kapcsolat-h2">Foglaljon időpontot ma</h2>
      <svg class="brush kapcsolat-brush" viewBox="0 0 200 10" preserveAspectRatio="none" aria-hidden="true">
        <path d="M1,2.6 L199,4.2 L199,5.6 L1,7.4 Z" fill="url(#brushgrad)"/>
      </svg>
      <p class="kapcsolat-sub">Örömmel várom. Keressen telefonon, e-mailben, vagy küldjön üzenetet az alábbi űrlapon.</p>
      <div class="kapcsolat-details">
        <div class="kapcsolat-item"><span class="kapcsolat-icon">📍</span><span>1126 Budapest, Dolgos utca 2. – 6B lépcsőház</span></div>
        <div class="kapcsolat-item"><span class="kapcsolat-icon">📞</span><a href="tel:+36203393399">+36 20 339 3399</a></div>
        <div class="kapcsolat-item"><span class="kapcsolat-icon">✉️</span><a href="mailto:info@szepsegterapeuta.hu">info@szepsegterapeuta.hu</a></div>
        <div class="kapcsolat-item"><span class="kapcsolat-icon">🕐</span><span>Hétfő–Vasárnap: 6:00–20:00</span></div>
      </div>
    </div>
    <form class="kapcsolat-form" name="contact-v3" method="POST" data-netlify="true">
      <input type="hidden" name="form-name" value="contact-v3" />
      <label class="form-field"><span>Neve</span><input type="text" name="name" required /></label>
      <label class="form-field"><span>E-mail címe</span><input type="email" name="email" required /></label>
      <label class="form-field"><span>Üzenete</span><textarea name="message" rows="5" required></textarea></label>
      <a href="#" class="btn-cut form-btn" onclick="this.closest('form').requestSubmit();return false;">
        <span class="lbl">Küldés
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
    </form>
  </div>
</section>

<style>
  .kapcsolat-sec{
    background: var(--bg);
    padding: 3rem 1.4rem 4rem;
  }
  .kapcsolat-grid{
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .kapcsolat-h2{
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 400;
    line-height: 1.08;
    margin: .4rem 0 0;
    color: var(--ink);
  }
  .kapcsolat-brush{ display:block; width:65px; height:9px; margin: .4rem 0 .9rem; }
  .kapcsolat-sub{
    color: var(--muted);
    font-family: var(--sans);
    font-size: .78rem;
    font-weight: 300;
    line-height: 1.65;
    margin-bottom: 1.4rem;
  }
  .kapcsolat-details{ display: flex; flex-direction: column; gap: .7rem; }
  .kapcsolat-item{
    display: flex;
    align-items: flex-start;
    gap: .6rem;
    font-family: var(--sans);
    font-size: .78rem;
    font-weight: 300;
    color: var(--muted);
  }
  .kapcsolat-item a{ color: var(--ink); }
  .kapcsolat-icon{ flex-shrink: 0; margin-top: .05rem; }

  .kapcsolat-form{ display: flex; flex-direction: column; gap: 1.1rem; }
  .form-field{
    display: flex;
    flex-direction: column;
    gap: .35rem;
    font-family: var(--sans);
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .kapcsolat-form input,
  .kapcsolat-form textarea{
    width: 100%;
    padding: .7rem 0;
    border: none;
    border-bottom: 1.5px solid rgba(58,63,62,.18);
    background: transparent;
    font-family: var(--sans);
    font-size: .88rem;
    font-weight: 300;
    color: var(--ink);
    outline: none;
    transition: border-color .2s;
  }
  .kapcsolat-form input:focus,
  .kapcsolat-form textarea:focus{ border-bottom-color: var(--green); }
  .kapcsolat-form textarea{ resize: vertical; min-height: 110px; }

  /* v3 levágott sarkú gomb */
  .btn-cut{
    display: inline-flex;
    background: conic-gradient(from 200deg at 50% 50%,rgba(168,201,106,0.12) 0%,rgba(168,201,106,0.5) 20%,#A8C96A 40%,#8FAE52 50%,#A8C96A 60%,rgba(168,201,106,0.4) 80%,rgba(168,201,106,0.12) 100%);
    clip-path: polygon(9px 0,100% 0,100% calc(100% - 9px),calc(100% - 9px) 100%,0 100%,0 9px);
    transition: .3s;
    align-self: flex-start;
  }
  .btn-cut .lbl{
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    white-space: nowrap;
    margin: 1.5px;
    background: var(--bg);
    clip-path: polygon(8px 0,100% 0,100% calc(100% - 8px),calc(100% - 8px) 100%,0 100%,0 8px);
    color: var(--ink);
    font-family: var(--sans);
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: .75rem .95rem;
    transition: .3s;
  }
  .btn-cut:hover .lbl{ background: var(--ink); color: #fff; }

  @media (min-width: 760px){
    .kapcsolat-grid{ grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: start; }
    .kapcsolat-h2{ font-size: 2rem; }
    .kapcsolat-sub{ font-size: .88rem; }
  }
</style>
