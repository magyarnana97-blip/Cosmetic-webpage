---
import type { T } from '../i18n/v3/hu';
const { tr } = Astro.props as { tr: T };
const cl = tr.closing;
---

<section class="closing-overlap scroll-exit" id="kezdjuk">
  <div class="closing-inner reveal">
    <h2>{cl.h2}</h2>
    <p>{cl.body}</p>
    <a href="#kapcsolat" class="btn-cut">
      <span class="lbl">{cl.cta}
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    </a>
  </div>
</section>

<style>
  .closing-overlap{padding:0 var(--page-margin) 2.4rem;margin-top:-180px;position:relative;z-index:10;}
  .closing-inner{text-align:center;background:var(--ink);padding:2.2rem var(--page-margin) 2rem;border-radius:18px;box-shadow:0 18px 48px rgba(30,35,33,.22);}
  .closing-inner h2{color:#fff;font-family:var(--serif);font-size:1.9rem;font-weight:400;line-height:1.08;margin-bottom:.8rem;}
  .closing-inner p{color:rgba(255,255,255,.72);font-family:var(--sans);font-size:var(--section-body);font-weight:300;margin:0 auto 1.6rem;line-height:1.65;max-width:280px;}
  .btn-cut{display:inline-flex;background:conic-gradient(from 200deg at 50% 50%,rgba(168,201,106,0.12) 0%,rgba(168,201,106,0.5) 20%,#A8C96A 40%,#8FAE52 50%,#A8C96A 60%,rgba(168,201,106,0.4) 80%,rgba(168,201,106,0.12) 100%);clip-path:polygon(9px 0,100% 0,100% calc(100% - 9px),calc(100% - 9px) 100%,0 100%,0 9px);transition:.3s;flex-shrink:0;}
  .btn-cut .lbl{display:inline-flex;align-items:center;gap:.45rem;white-space:nowrap;margin:1.5px;background:var(--ink);clip-path:polygon(8px 0,100% 0,100% calc(100% - 8px),calc(100% - 8px) 100%,0 100%,0 8px);color:#fff;font-family:var(--sans);font-size:.6rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:.75rem .95rem;transition:.3s;}
  .btn-cut:hover .lbl{background:var(--green-deep);color:#fff;}
  @media (min-width:760px){.closing-overlap{padding:0 var(--page-margin) 2.8rem;margin-top:-200px;}.closing-inner{max-width:1000px;margin-left:auto;margin-right:auto;}.closing-inner p{max-width:420px;}}
</style>
