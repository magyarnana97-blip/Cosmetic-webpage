---
import type { T } from '../i18n/v3/hu';
const { tr } = Astro.props as { tr: T };
---

<section class="kartyak scroll-exit">
  <div class="kv-grid">
    {tr.cards.map((card, i) => (
      <div class={`kv-card reveal d${i+1}`}>
        <p class="kv-num">{String(i+1).padStart(2,'0')}</p>
        <h3 class="kv-title" style="white-space:pre-line">{card.title}</h3>
        <p class="kv-desc">{card.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .kartyak{background:var(--bg);padding:2.2rem var(--page-margin) 1rem;}
  .kv-grid{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;}
  .kv-card{border-top:1.5px solid var(--line);padding-top:.9rem;}
  .kv-num{font-size:.58rem;font-weight:700;letter-spacing:.22em;color:var(--green);margin-bottom:.55rem;}
  .kv-title{font-family:var(--serif);font-size:1rem;font-weight:400;line-height:1.18;color:var(--ink);margin-bottom:.5rem;}
  .kv-desc{font-size:.75rem;font-weight:300;color:var(--muted);line-height:1.55;}
  @media(max-width:540px){.kv-grid{grid-template-columns:1fr;gap:.9rem;}}
</style>
