---
import type { T } from '../i18n/v3/hu';
const { tr } = Astro.props as { tr: T };
const kz = tr.treatments;
---

<section class="kezelesek" id="kezelesek">

  <div class="kz-head">
    <div class="kz-head-text">
      <span class="eyebrow">{kz.eyebrow}</span>
      <h2>{kz.h2} <em>{kz.h2em} <span class="kz-blk">{kz.h2bold}</span> {kz.h2end}</em></h2>
      <p class="kz-sub">{kz.sub}</p>
    </div>
    <div class="kz-orb">
      <video class="kz-orb-vid" src="/orb.mp4?5" muted loop playsinline preload="auto" poster="/orb-poster.jpg?5"></video>
    </div>
  </div>

  <ul class="kz-list">
    {kz.categories.map(cat => (
      <li class="kz-item">
        <span class="kz-node"><span class="kz-node-ph">Ikon</span></span>
        <div class="kz-content">
          <div class="kz-bar">
            <span class="kz-tt">{cat.title}</span>
            <button class="kz-plus" aria-expanded="false" aria-label={cat.ariaLabel}></button>
          </div>
          <p class="kz-desc">{cat.desc}</p>
          <div class="kz-detail">
            <ul class="kz-price">
              {cat.items.map(item => (
                <li>
                  <span class="kz-pn">{item.name}</span>
                  <span class="kz-pp">{item.price}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </li>
    ))}
  </ul>

</section>

<style>
  .kezelesek{background:var(--bg);padding:10px 1.1rem 1.4rem 1.65rem;margin-top:0;position:relative;z-index:1;}
  .kz-head{position:relative;min-height:150px;max-width:1000px;margin:0 auto;isolation:isolate;}
  .kz-head-text{max-width:46%;min-width:0;position:relative;z-index:5;transform:translate(0,-4px);}
  .kezelesek .eyebrow{font-size:.525rem;margin-bottom:.74rem;}
  .kz-head h2{font-size:19px;line-height:1.08;margin:0 0 .45rem;}
  .kz-head h2 .kz-blk{color:var(--ink);}
  .kz-sub{color:var(--muted);font-size:10px;line-height:1.45;}
  .kz-orb{position:absolute;top:0;right:0;width:290px;z-index:0;background:var(--bg);transform:translate(37px,-17px);transform-origin:top right;}
  .kz-orb-vid{width:100%;height:auto;display:block;-webkit-mask-image:radial-gradient(76% 62% at 50% 60%,#000 36%,transparent 84%);mask-image:radial-gradient(76% 62% at 50% 60%,#000 36%,transparent 84%);}
  .kz-list{list-style:none;position:relative;display:flex;flex-direction:column;gap:1.05rem;max-width:1000px;margin:1.4rem auto;padding:0;}
  .kz-list::before{content:'';position:absolute;left:25px;top:26px;bottom:26px;width:6px;border-radius:3px;z-index:0;background:linear-gradient(180deg,rgba(255,255,255,.15),rgba(255,255,255,.95) 16%,rgba(255,255,255,.55) 50%,rgba(255,255,255,.95) 84%,rgba(255,255,255,.15));background-size:100% 240%;box-shadow:0 0 7px rgba(255,255,255,.85),0 0 0 1px rgba(150,170,110,.14);animation:kzShimmer 5s ease-in-out infinite;}
  @keyframes kzShimmer{0%,100%{background-position:0 0;}50%{background-position:0 -100%;}}
  .kz-item{position:relative;display:flex;align-items:flex-start;gap:.4rem;z-index:1;}
  .kz-node{flex-shrink:0;width:51px;height:51px;border-radius:50%;background:var(--bg);border:1.5px solid rgba(255,255,255,.95);box-shadow:0 0 9px rgba(255,255,255,.85),0 2px 9px rgba(120,140,90,.18);display:flex;align-items:center;justify-content:center;position:relative;z-index:2;}
  .kz-node-ph{font-size:.4rem;letter-spacing:.06em;text-transform:uppercase;color:var(--green-deep);opacity:.7;}
  .kz-content{flex:1;min-width:0;padding-top:.15rem;}
  .kz-bar{width:100%;display:flex;align-items:center;justify-content:space-between;gap:.6rem;padding:.3rem 0 .15rem;}
  .kz-bar .kz-tt{font-family:var(--sans);font-size:11px;letter-spacing:.05em;text-transform:uppercase;font-weight:600;color:var(--ink);margin:0;}
  .kz-desc{color:var(--muted);font-size:11px;line-height:1.45;max-width:202px;margin:.05rem 0 .25rem;}
  .kz-plus{position:relative;flex-shrink:0;width:28px;height:28px;border-radius:50%;border:1.5px solid rgba(255,255,255,.7);background:transparent;cursor:pointer;transition:.25s;}
  .kz-plus::before,.kz-plus::after{content:'';position:absolute;top:50%;left:50%;width:10px;height:1.5px;background:var(--ink);border-radius:1px;translate:-50% -50%;transition:transform .25s,opacity .25s;}
  .kz-plus::after{transform:rotate(90deg);}
  .kz-plus[aria-expanded="true"]::after{transform:rotate(0);opacity:0;}
  .kz-detail{display:grid;grid-template-rows:0fr;transition:grid-template-rows .38s cubic-bezier(.22,1,.36,1);}
  .kz-detail>*{overflow:hidden;}
  .kz-item.open .kz-detail{grid-template-rows:1fr;}
  .kz-price{list-style:none;padding:0;margin:.4rem 0 .8rem;display:flex;flex-direction:column;gap:.45rem;}
  .kz-price li{display:flex;justify-content:space-between;gap:.5rem;font-size:10px;border-bottom:1px solid rgba(255,255,255,.08);padding-bottom:.35rem;}
  .kz-pn{color:var(--muted);flex:1;}
  .kz-pp{color:var(--ink);font-weight:600;white-space:nowrap;flex-shrink:0;}
  @media (min-width:760px){
    .kz-head-text{max-width:55%;}
    .kz-head h2{font-size:1.55rem;}
    .kz-sub{font-size:.82rem;}
    .kz-desc{max-width:500px;font-size:.82rem;}
    .kz-price li{font-size:.82rem;}
    .kz-bar .kz-tt{font-size:.9rem;}
  }
</style>

<script>
  document.querySelectorAll('.kz-plus').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.kz-item');
      const isOpen = item?.classList.contains('open');
      document.querySelectorAll('.kz-item.open').forEach(el => {
        el.classList.remove('open');
        el.querySelector('.kz-plus')?.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen && item) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
