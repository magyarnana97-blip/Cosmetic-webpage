---
import Layout from '../layouts/Layout.astro';
import Animations from '../components/Animations.astro';
import { getSection } from '../i18n/utils';

const locale = 'hu';
const meta         = getSection<any>(locale, 'meta');
const hero         = getSection<any>(locale, 'hero');
const about        = getSection<any>(locale, 'about');
const services     = getSection<any>(locale, 'services');
const testimonials = getSection<any>(locale, 'testimonials');
const faq          = getSection<any>(locale, 'faq');
const contact      = getSection<any>(locale, 'contact');

const steps = [
  { n: '01', title: 'Időpontfoglalás', desc: 'Válassz egy számodra megfelelő időpontot online vagy telefonon. Az első konzultáció ingyenes.', img: 'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=600&q=80' },
  { n: '02', title: 'Személyes konzultáció', desc: 'Megvizsgálom bőröd állapotát és egyedi kezelési tervet állítok össze számodra.', img: 'https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?w=600&q=80' },
  { n: '03', title: 'Kezelés és ápolás', desc: 'Természetes, QMS Medicosmetics alapanyagokkal végzett professzionális kezelés, teljes kényelemben.', img: 'https://images.unsplash.com/photo-1515377905703-c4788e51af15?w=600&q=80' },
];

const posts = [
  {
    img: 'https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=600&q=80',
    tag: 'Trendek',
    date: '2026. máj. 25.',
    title: 'Hová tart a kozmetika 2026-ban?',
    excerpt: 'A szakma ma már nem csak krémekről szól — a személyre szabás, a skinimalizmus és az okos technológia együtt formálja a bőrápolás jövőjét.',
    body: `A kozmetika ma már messze nem csak a „szépítő kezelésekről" szól. Az elmúlt években a szakma látványosan elmozdult abba az irányba, hogy a bőrápolás egyszerre legyen tudatosabb, személyre szabottabb és tudományosabban megalapozott. Ez a változás a hétköznapi vendégek számára is jól látható: egyre többen keresnek olyan megoldásokat, amelyek nem ígérnek csodát egyik napról a másikra, hanem valóban a bőr állapotához, életmódjához és érzékenységéhez igazodnak.\n\nAz egyik legerősebb irány a skinimalizmus, vagyis a kevesebb, de okosan megválasztott termékek használata. A korábbi „minél több, annál jobb" szemlélet helyett ma sok szakember azt vallja, hogy a bőr gyakran jobban reagál egy egyszerűbb, átgondolt rutinra. Ennek van is logikája: ha túl sok hatóanyagot, túl sok réteget vagy egymással nehezen összeegyeztethető terméket használunk, a bőr könnyen irritálttá válhat, a barrierje sérülhet, és végül pont az ellenkező hatást érjük el, mint amit szerettünk volna.\n\nEzzel párhuzamosan egyre fontosabbá válik a személyre szabás. Ugyanaz a krém, ugyanaz a kezelés vagy ugyanaz a hatóanyag nem működik mindenkinél egyformán. A szakma ezért ma már sokkal inkább arra törekszik, hogy a vendég bőrtípusát, bőrproblémáját, életkorát, érzékenységét és napi szokásait is figyelembe vegye.\n\nA technológia közben egyre látványosabban belép ebbe a világba. A bőrértékelésben megjelentek a digitális eszközök, az intelligensebb diagnosztikai rendszerek és a hatóanyagok célzottabb bejuttatására szolgáló fejlesztések is. Fontos azonban látni, hogy ezek nem helyettesítik a kozmetikust, hanem segítik őt.\n\nA kozmetika jövője tehát nem a túlzásokról szól, hanem a tudatosságról. Kevesebb ígéret, több valódi figyelem — és ez az, amiben egy jó kozmetikus igazán számít.`,
    sources: [
      { label: 'Artificial intelligence in cosmetic dermatology (PubMed, 2024)', url: 'https://pubmed.ncbi.nlm.nih.gov/39188183/' },
      { label: 'Nanocarriers in skincare: current trends (PubMed, 2025)', url: 'https://pubmed.ncbi.nlm.nih.gov/41014067/' },
      { label: 'Evaluating efficacy and innovation in skin care (PMC, 2025)', url: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC12408269/' },
    ]
  },
  {
    img: 'https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?w=600&q=80',
    tag: 'Szakmai',
    date: '2026. máj. 25.',
    title: 'Mennyire hatásosak valójában a kozmetikai termékek?',
    excerpt: 'A dobozon szereplő ígéret és a valódi tudományos bizonyíték között sokszor komoly a szakadék. Mutatjuk, mire érdemes figyelni.',
    body: `Sokan ma is úgy vesznek kozmetikumot, mintha a dobozon szereplő ígéret önmagában garancia lenne az eredményre. A valóság ennél jóval összetettebb: egy termék hatásossága nemcsak attól függ, mi van benne, hanem attól is, milyen koncentrációban, milyen formulában, és milyen bőrtípuson használják.\n\nA tudományos vizsgálatok egyre gyakrabban mutatják meg, hogy bizonyos összetevők valóban képesek javítani a bőr hidratáltságát, rugalmasságát vagy a ráncok megjelenését — de az eredmény nem mindig látványos az első napon vagy akár az első héten. Ez különösen fontos akkor, amikor a vendégek gyors, azonnali változást várnak.\n\nA kozmetikus szerepe ezért nem egyszerűen az, hogy terméket ajánljon, hanem az, hogy elmagyarázza: a bőrön mérhető javulás időt, következetes használatot és megfelelő rutinba illesztést igényel. Sok esetben a legjobb eredmény nem egy „csodakrémből", hanem egy jól felépített otthoni ápolási rendszerből és a professzionális kezelésből együtt születik.\n\nKülönösen érdekes terület a botanikai eredetű hatóanyagok és a fermentált összetevők kutatása — több tanulmány ígéretes javulást mutat hidratáltság, textúra és rugalmasság terén. Ugyanakkor a marketing szöveg és a bizonyíték között mindig érdemes különbséget tenni, mert nem minden „természetes" formula egyformán jól vizsgált.\n\nHa tehát legközelebb terméket választasz, érdemes megkérdezni: van-e mögötte valódi vizsgálat, és illik-e az én bőröm aktuális állapotához? Ebben pontosan az a kozmetikus tud segíteni, aki ismeri a bőrödet.`,
    sources: [
      { label: 'Efficacy of fermented lysate in anti-aging cosmetics (PubMed, 2024)', url: 'https://pubmed.ncbi.nlm.nih.gov/37977853/' },
      { label: 'Anti-wrinkle efficacy of phenolic acids (PubMed, 2024)', url: 'https://pubmed.ncbi.nlm.nih.gov/38943252/' },
      { label: 'Efficacy and Safety of Plant-Based Products (PubMed, 2025)', url: 'https://pubmed.ncbi.nlm.nih.gov/39654386/' },
    ]
  },
  {
    img: 'https://images.unsplash.com/photo-1556228578-8c89e6adf883?w=600&q=80',
    tag: 'Fenntarthatóság',
    date: '2026. máj. 25.',
    title: 'Fenntartható kozmetika: divat vagy tartós irány?',
    excerpt: 'A „természetes" és „bio" jelzők mögött nem mindig van, amit gondolunk. Nézzük meg, mit jelent valójában a felelős bőrápolás.',
    body: `A fenntarthatóság ma már nem külön „szépészeti extra", hanem a kozmetikai ipar egyik komoly fejlődési iránya. A friss áttekintések szerint a szakma egyre nagyobb figyelmet fordít az alacsonyabb környezeti terhelésre, az etikus alapanyag-beszerzésre, az energiahatékony működésre és az újrahasznosítható csomagolásokra.\n\nEz a változás nemcsak a gyártókat érinti, hanem a szalonokat és a vendégeket is. Egyre több fogyasztó kérdez rá arra, hogy egy termék mennyire környezetbarát, honnan származik az összetevő, és mennyire biztonságos hosszú távon.\n\nFontos azonban, hogy a fenntarthatóságot ne keverjük össze automatikusan a „természetes" vagy „bio" jelzővel. Egy alapanyag lehet növényi eredetű, de ettől még nem feltétlenül jobb vagy kevésbé irritáló — és egy jól megtervezett szintetikus összetevő is lehet biztonságosabb és stabilabb.\n\nA modern kozmetika ezért ma már nem fekete-fehér módon gondolkodik. A kérdés inkább az, hogyan lehet egyszerre hatékony, biztonságos és felelősen előállított termékeket használni. Ez a szemlélet hosszú távon valószínűleg még fontosabb lesz, mert a piac és a fogyasztók is egyre inkább ebbe az irányba mozdulnak.\n\nHa egy szalon fenntartható termékekkel dolgozik és ezt átláthatóan kommunikálja, az ma már versenyelőnyt is jelent — mert a tudatos vásárló pontosan ezt keresi.`,
    sources: [
      { label: 'Sustainability in Cosmetic Dermatology (PMC, 2025)', url: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC12454804/' },
      { label: 'Sustainable cosmetic ingredient alternatives (PMC, 2025)', url: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC12877994/' },
      { label: 'From plant genetic resources to cosmetic active ingredients (PMC, 2025)', url: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC12495392/' },
    ]
  },
];
---

<Layout locale={locale} title={meta.title} description={meta.description}>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-mobile">
      <div class="hm-logo-wrap">
        <div class="hm-logo-box">
          <img src="/logo.jpeg" alt="Szépségterapeuta" class="hm-logo" />
        </div>
      </div>
      <div class="hm-tiles">
        <a href="#services" class="hmt hmt-green">
          <span class="hmt-circle">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="16" stroke="currentColor" stroke-width="1.4"/><path d="M18 8c0 0-7 5.5-7 12a7 7 0 0014 0c0-6.5-7-12-7-12z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M18 20v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          </span>
          <span class="hmt-name">FRESH GREEN</span>
          <span class="hmt-sub">Időpontfoglalás</span>
        </a>
        <a href="#about" class="hmt hmt-beige">
          <span class="hmt-circle hmt-circle-beige">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="16" stroke="currentColor" stroke-width="1.4"/><path d="M12 24c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M18 10c2.21 0 4 1.79 4 4s-1.79 4-4 4-4-1.79-4-4 1.79-4 4-4z" stroke="currentColor" stroke-width="1.4"/></svg>
          </span>
          <span class="hmt-name">WARM BEIGE</span>
          <span class="hmt-sub">Rólam</span>
        </a>
      </div>
      <div class="hm-btns">
        <a href="#contact" class="btn-primary hm-btn-main">{hero.ctaPrimary}</a>
        <a href="#about" class="hm-btn-arrow">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.4"/><path d="M7 10h6M10 7l3 3-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="hm-footer">
        <span class="hm-footer-icon"><svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="1.2"/><path d="M14 6c0 0-5.5 4-5.5 9a5.5 5.5 0 0011 0C19.5 10 14 6 14 6z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M14 15v3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg></span>
        <span class="hm-footer-txt">TERMÉSZETES</span>
        <p class="hm-slogan">Szépség kívül és belül – rólad szól.</p>
      </div>
    </div>

    <div class="hero-desktop">
      <div class="hero-inner">
        <div class="hero-text">
          <span class="sec-label reveal">{hero.badge}</span>
          <h1 class="reveal reveal-delay-1">{hero.title}</h1>
          <div class="hero-divider reveal reveal-delay-2"></div>
          <p class="hero-sub reveal reveal-delay-2">{hero.subtitle}</p>
          <p class="hero-tagline reveal reveal-delay-3">Természetes szépség, harmónia, önbizalom</p>
          <div class="hero-btns reveal reveal-delay-4">
            <a href="#contact" class="btn-primary">{hero.ctaPrimary}</a>
            <a href="#about" class="btn-outline">{hero.ctaSecondary}</a>
          </div>
        </div>
        <div class="hero-img-wrap reveal-right">
          <img src="/spa-bg.png" alt="Természetes kozmetikai kezelés" width="560" height="660" loading="eager" />
        </div>
      </div>
      <div class="hero-stats">
        {hero.stats.map((s: any) => (
          <div class="stat-item reveal">
            <span class="stat-n" data-target={s.n.replace(/[^0-9]/g,'')} data-suffix={s.n.replace(/[0-9]/g,'')}>0</span>
            <span class="stat-l">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee-wrap">
    <div class="marquee-track">
      {['Természetes szépség','QMS Medicosmetics','Harmónia','20+ év tapasztalat','Szépségterápia','Budapest','Önbizalom','Bőrápolás','Természetes szépség','QMS Medicosmetics','Harmónia','20+ év tapasztalat','Szépségterápia','Budapest','Önbizalom','Bőrápolás'].map(txt => (
        <span class="marquee-item"><span class="marquee-dot"></span>{txt}</span>
      ))}
    </div>
  </div>

  <!-- RÓLAM -->
  <section class="sec about-sec" id="about">
    <div class="sec-inner about-grid">
      <div class="about-img-wrap reveal-left">
        <img src="/marianna.png" alt={about.imageAlt} width="480" height="560" loading="lazy" />
      </div>
      <div class="about-text">
        <span class="sec-label reveal">{about.sectionLabel}</span>
        <h2 class="reveal reveal-delay-1">{about.title}</h2>
        <div class="divider reveal reveal-delay-1" style="margin:1rem 0"></div>
        <p class="about-body reveal reveal-delay-2">{about.body}</p>
        <div class="cert-row reveal reveal-delay-3">
          {about.certs.map((c: string) => <span class="cert-tag">{c}</span>)}
        </div>
        <a href="#contact" class="btn-primary reveal reveal-delay-4" style="margin-top:2rem;display:inline-block">Időpontot foglalok</a>
      </div>
    </div>
  </section>

  <!-- HOGYAN MŰKÖDIK -->
  <section class="sec steps-sec">
    <div class="sec-inner">
      <div class="sec-head">
        <span class="sec-label reveal">A folyamat</span>
        <h2 class="reveal reveal-delay-1">Hogyan működik?</h2>
        <div class="divider reveal reveal-delay-1"></div>
        <p class="reveal reveal-delay-2">Három egyszerű lépés, és már úton vagy az egészséges, sugárzó bőr felé.</p>
      </div>
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-card gallery-item">
            <div class="step-img-wrap">
              <img src={s.img} alt={s.title} loading="lazy" />
              <span class="step-number">{s.n}</span>
            </div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- KEZELÉSEK -->
  <section class="sec services-sec" id="services">
    <div class="sec-inner">
      <div class="sec-head">
        <span class="sec-label reveal">{services.sectionLabel}</span>
        <h2 class="reveal reveal-delay-1">{services.title}</h2>
        <div class="divider reveal reveal-delay-1"></div>
        <p class="reveal reveal-delay-2">{services.subtitle}</p>
      </div>
      <div class="svc-grid">
        {services.items.map((s: any) => (
          <article class="svc-card gallery-item">
            <div class="svc-icon"><svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="1.5"/><path d="M14 8v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
            <span class="svc-tag">{s.tag}</span>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            <div class="svc-meta">
              <span class="svc-duration">{s.duration}</span>
              <span class="svc-price">{s.price}</span>
            </div>
            <a href="#contact" class="btn-outline svc-btn">Foglalás</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="sec blog-sec">
    <div class="sec-inner">
      <div class="sec-head">
        <span class="sec-label reveal">Tippek &amp; útmutatók</span>
        <h2 class="reveal reveal-delay-1">Bőrápolási blog</h2>
        <div class="divider reveal reveal-delay-1"></div>
        <p class="reveal reveal-delay-2">Szakmai tippek, kezelési útmutatók és bőrápolási trendek közvetlenül a rendelőből.</p>
      </div>
      <div class="blog-grid">
        {posts.map((p, i) => (
          <article class="blog-card gallery-item">
            <div class="blog-img-wrap">
              <img src={p.img} alt={p.title} loading="lazy" />
              <span class="blog-tag">{p.tag}</span>
            </div>
            <div class="blog-body">
              <p class="blog-date">{p.date}</p>
              <h3>{p.title}</h3>
              <p class="blog-excerpt">{p.excerpt}</p>
              <button class="blog-link blog-open-btn" data-index={i}>Tovább olvasom →</button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- BLOG MODALS -->
  {posts.map((p, i) => (
    <dialog id={`modal-hu-${i}`} class="blog-modal">
      <div class="modal-inner">
        <button class="modal-close blog-close-btn" data-id={`modal-hu-${i}`} aria-label="Bezárás">✕</button>
        <span class="blog-tag modal-tag">{p.tag}</span>
        <p class="blog-date">{p.date}</p>
        <h2 class="modal-title">{p.title}</h2>
        <img src={p.img} alt={p.title} class="modal-img" loading="lazy" />
        <div class="modal-body">
          {p.body.split('\n\n').map((para: string) => <p>{para}</p>)}
        </div>
        <div class="modal-sources">
          <h4>Források</h4>
          <ul>
            {p.sources.map((s: any) => (
              <li><a href={s.url} target="_blank" rel="noopener noreferrer">{s.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </dialog>
  ))}

  <!-- VÉLEMÉNYEK -->
  <section class="sec testi-sec">
    <div class="sec-inner">
      <div class="sec-head">
        <span class="sec-label reveal">{testimonials.sectionLabel}</span>
        <h2 class="reveal reveal-delay-1">{testimonials.title}</h2>
        <div class="divider reveal reveal-delay-1"></div>
      </div>
      <div class="testi-grid">
        {testimonials.items.map((t: any) => (
          <figure class="testi-card gallery-item">
            <div class="testi-quote-icon">❝</div>
            <blockquote><p>{t.quote}</p></blockquote>
            <figcaption>{t.author}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- GYIK -->
  <section class="sec faq-sec">
    <div class="sec-inner faq-inner">
      <div class="sec-head">
        <span class="sec-label reveal">{faq.sectionLabel}</span>
        <h2 class="reveal reveal-delay-1">{faq.title}</h2>
        <div class="divider reveal reveal-delay-1"></div>
      </div>
      <dl class="faq-list">
        {faq.items.map((item: any) => (
          <div class="faq-row reveal"><dt>{item.q}</dt><dd>{item.a}</dd></div>
        ))}
      </dl>
    </div>
  </section>

  <!-- KAPCSOLAT -->
  <section class="sec contact-sec" id="contact">
    <div class="sec-inner contact-grid">
      <div class="contact-info">
        <span class="sec-label reveal">{contact.sectionLabel}</span>
        <h2 class="reveal reveal-delay-1">{contact.title}</h2>
        <div class="divider reveal reveal-delay-1" style="margin:1rem 0"></div>
        <p class="contact-sub reveal reveal-delay-2">{contact.subtitle}</p>
        <div class="contact-details reveal reveal-delay-3">
          <div class="contact-item"><span class="contact-icon">📍</span><span>{contact.address}</span></div>
          <div class="contact-item"><span class="contact-icon">📞</span><a href={`tel:${contact.phone}`}>{contact.phone}</a></div>
          <div class="contact-item"><span class="contact-icon">✉️</span><a href={`mailto:${contact.email}`}>{contact.email}</a></div>
          <div class="contact-item"><span class="contact-icon">🕐</span><span>{contact.hours}</span></div>
        </div>
      </div>
      <form class="contact-form reveal reveal-delay-2" name="contact" method="POST" data-netlify="true">
        <input type="hidden" name="form-name" value="contact" />
        <label class="form-field"><span>{contact.formName}</span><input type="text" name="name" required /></label>
        <label class="form-field"><span>{contact.formEmail}</span><input type="email" name="email" required /></label>
        <label class="form-field"><span>{contact.formMessage}</span><textarea name="message" rows="5" required></textarea></label>
        <button type="submit" class="btn-primary">{contact.formSubmit}</button>
      </form>
    </div>
  </section>

  <Animations />

</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.blog-open-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = (btn as HTMLElement).dataset.index;
        const modal = document.getElementById('modal-hu-' + idx) as HTMLDialogElement | null;
        modal?.showModal();
      });
    });
    document.querySelectorAll('.blog-close-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id;
        const modal = document.getElementById(id!) as HTMLDialogElement | null;
