---
/**
 * src/pages/index.astro
 * ─────────────────────────────────────────────────────
 * A gyökér URL (/) magyar nyelvű főoldala.
 * Többi locale: src/pages/[lang]/index.astro
 */

import { t, alternateUrls } from '../i18n/v3/index';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Kartyak from '../components/Kartyak.astro';
import Fejlesztunk from '../components/Fejlesztunk.astro';
import Kezelesek from '../components/Kezelesek.astro';
import Rolam from '../components/Rolam.astro';
import Boreelemzes from '../components/Boreelemzes.astro';
import Kapcsolat from '../components/Kapcsolat.astro';
import Footer from '../components/Footer.astro';

const tr = t('hu');
const alts = alternateUrls('/');
---

<!DOCTYPE html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={tr.meta.description} />
  <title>{tr.meta.title}</title>

  {Object.entries(alts).map(([l, href]) => (
    <link rel="alternate" hreflang={l} href={`https://szepsegterapeuta.hu${href}`} />
  ))}
  <link rel="alternate" hreflang="x-default" href="https://szepsegterapeuta.hu/" />
  <link rel="canonical" href="https://szepsegterapeuta.hu/" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ── Nyelvajanlo sav ────────────────────────────── */
    #lang-suggest {
      display: none;
      position: fixed;
      bottom: 1.75rem;
      left: 50%;
      transform: translateX(-50%) translateY(120%);
      z-index: 9999;
      width: min(480px, 92vw);

      /* glassmorphism */
      background: rgba(247, 246, 241, 0.72);
      backdrop-filter: blur(18px) saturate(1.6);
      -webkit-backdrop-filter: blur(18px) saturate(1.6);
      border: 1px solid rgba(168, 201, 106, 0.35);
      border-radius: 16px;
      box-shadow:
        0 8px 32px rgba(80, 100, 60, 0.13),
        0 1.5px 0 rgba(255,255,255,0.55) inset;

      padding: 1rem 1.25rem 1rem 1.4rem;
      display: flex;
      align-items: center;
      gap: 1rem;

      transition: transform 0.52s cubic-bezier(0.16, 1, 0.3, 1),
                  opacity 0.52s cubic-bezier(0.16, 1, 0.3, 1);
      opacity: 0;
    }
    #lang-suggest.ls-visible {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }
    #lang-suggest.ls-hiding {
      transform: translateX(-50%) translateY(120%);
      opacity: 0;
    }

    /* kis globális ikon bal oldalt */
    #lang-suggest-icon {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: rgba(168, 201, 106, 0.18);
      border: 1px solid rgba(168, 201, 106, 0.4);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #6e8467;
    }

    /* szöveg rész */
    #lang-suggest-body {
      flex: 1;
      min-width: 0;
    }
    #lang-suggest-label {
      display: block;
      font-family: var(--sans, 'Inter', system-ui);
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #8a9e82;
      margin-bottom: 0.2rem;
    }
    #lang-suggest-text {
      display: block;
      font-family: var(--sans, 'Inter', system-ui);
      font-size: 0.875rem;
      font-weight: 400;
      color: #3a4535;
      line-height: 1.4;
    }

    /* CTA gomb */
    #lang-suggest-link {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: linear-gradient(135deg, #a8c96a 0%, #7fa852 100%);
      color: #fff;
      border-radius: 8px;
      padding: 0.5rem 1rem;
      font-family: var(--sans, 'Inter', system-ui);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-decoration: none;
      white-space: nowrap;
      box-shadow: 0 2px 10px rgba(120, 168, 82, 0.35);
      transition: filter 0.2s ease, transform 0.2s ease;
    }
    #lang-suggest-link:hover {
      filter: brightness(1.08);
      transform: translateY(-1px);
    }
    #lang-suggest-link svg {
      width: 12px;
      height: 12px;
      stroke: currentColor;
      stroke-width: 2.5;
      fill: none;
    }

    /* bezárás gomb */
    #lang-suggest-close {
      flex-shrink: 0;
      background: none;
      border: none;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: #9aaa90;
      transition: background 0.18s ease, color 0.18s ease;
      padding: 0;
    }
    #lang-suggest-close:hover {
      background: rgba(110, 132, 103, 0.12);
      color: #4a5e44;
    }
    #lang-suggest-close svg {
      width: 14px;
      height: 14px;
      stroke: currentColor;
      stroke-width: 2;
      fill: none;
    }
  </style>

  <script is:inline>
    if (window.location.hash) {
      history.replaceState(null, '', window.location.pathname + window.location.search);
    }
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
    if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
    window.addEventListener('pageshow', function() {
      window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
    });
  </script>
</head>

<body>

  <!-- ── Nyelvajanlo sav (futurisztikus, glassmorphism) ── -->
  <div id="lang-suggest" role="region" aria-label="Language suggestion">
    <!-- globális ikon -->
    <div id="lang-suggest-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
        <circle cx="12" cy="12" r="10"/>
        <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
    </div>
    <!-- szöveg -->
    <div id="lang-suggest-body">
      <span id="lang-suggest-label">Language</span>
      <span id="lang-suggest-text"></span>
    </div>
    <!-- CTA -->
    <a id="lang-suggest-link" href="#">
      <span id="lang-suggest-link-text"></span>
      <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <!-- bezárás -->
    <button id="lang-suggest-close" aria-label="Close">
      <svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/></svg>
    </button>
  </div>

  <Nav tr={tr} locale="hu" />
  <Hero tr={tr} />
  <Kartyak tr={tr} />
  <Fejlesztunk tr={tr} />
  <Kezelesek tr={tr} />
  <Rolam tr={tr} />
  <Boreelemzes tr={tr} />
  <Kapcsolat tr={tr} />
  <Footer tr={tr} locale="hu" />

  <script>
    if ('scrollRestoration' in history) history.scrollRestoration = 'manual';

    // ── Nyelvajanlo logika ──────────────────────────────
    (function() {
      var dismissed = sessionStorage.getItem('lang-suggest-dismissed');
      if (dismissed) return;

      var lang = (navigator.language || '').toLowerCase().split('-')[0];
      var suggest = document.getElementById('lang-suggest');
      var txt     = document.getElementById('lang-suggest-text');
      var lnk     = document.getElementById('lang-suggest-link');
      var lnkTxt  = document.getElementById('lang-suggest-link-text');
      var closeBtn= document.getElementById('lang-suggest-close');
      if (!suggest || !txt || !lnk || !lnkTxt || !closeBtn) return;

      var config = null;
      if (lang === 'ja') {
        config = { text: '\u65e5\u672c\u8a9e\u3067\u3054\u89a7\u306b\u306a\u308a\u307e\u3059\u304b\uff1f', btnLabel: '\u65e5\u672c\u8a9e\u3067\u8868\u793a', href: '/ja' };
      } else if (lang === 'ko') {
        config = { text: '\ud55c\uad6d\uc5b4\ub85c \ubcf4\uc2dc\uaca0\uc5b4\uc694?', btnLabel: '\ud55c\uad6d\uc5b4\ub85c \ubcf4\uae30', href: '/ko' };
      } else if (lang !== 'hu') {
        config = { text: 'Would you prefer this page in English?', btnLabel: 'View in English', href: '/en' };
      }
      if (!config) return;

      txt.textContent    = config.text;
      lnkTxt.textContent = config.btnLabel;
      lnk.href           = config.href;

      // megjelenes animacioval
      suggest.style.display = 'flex';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          suggest.classList.add('ls-visible');
        });
      });

      function dismiss() {
        sessionStorage.setItem('lang-suggest-dismissed', '1');
        suggest.classList.remove('ls-visible');
        suggest.classList.add('ls-hiding');
        setTimeout(function() { suggest.style.display = 'none'; }, 550);
      }

      closeBtn.addEventListener('click', dismiss);
      lnk.addEventListener('click', function() {
        sessionStorage.setItem('lang-suggest-dismissed', '1');
      });

      // 8 masodperc utan automatikusan eltűnik
      setTimeout(dismiss, 8000);
    })();

    window.__playNoScroll = function(v) {
      const sy = window.scrollY;
      try { const p = v.play(); if (p && p.catch) p.catch(() => {}); } catch(e) {}
      const fix = () => { if (Math.abs(window.scrollY - sy) > 2) window.scrollTo(0, sy); };
      requestAnimationFrame(fix); setTimeout(fix, 40); setTimeout(fix, 120);
    };

    (() => {
      const hv = document.querySelector('.hero-video');
      if (!hv) return;
      const setRate = () => { hv.playbackRate = 0.85; };
      hv.addEventListener('loadedmetadata', setRate);
      hv.addEventListener('play', setRate);
      setRate();
    })();

    (() => {
      const ov = document.querySelector('.kz-orb-vid');
      if (!ov) return;
      const io = new IntersectionObserver(function(es) {
        es.forEach(function(e) {
          if (e.isIntersecting) { var p = ov.play(); if (p && p.catch) p.catch(function() {}); }
          else { try { ov.pause(); } catch(_) {} }
        });
      }, { threshold: 0.25 });
      io.observe(ov);
    })();

    const burger = document.getElementById('burger');
    const drawer = document.getElementById('drawer');
    burger?.addEventListener('click', () => {
      burger.classList.toggle('open');
      drawer?.classList.toggle('open');
    });
    drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      burger?.classList.remove('open');
      drawer.classList.remove('open');
    }));

    const io = new IntersectionObserver(
      (es) => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
      { threshold: .12 }
    );
    document.querySelectorAll('.reveal, .reveal-media').forEach(el => io.observe(el));

    (() => {
      const v = document.getElementById('dropvid');
      if (!v) return;
      let teased = false, centeredPlayed = false;
      const teaser = () => {
        if (teased) return; teased = true;
        try { v.currentTime = 0; } catch(e) {}
        window.__playNoScroll(v);
        setTimeout(() => { try { if (!centeredPlayed) { v.pause(); v.currentTime = 0.5; } } catch(e) {} }, 500);
      };
      if (v.readyState >= 2) teaser(); else v.addEventListener('loadeddata', teaser, { once: true });
      const cio = new IntersectionObserver((es) => {
        es.forEach(e => {
          if (e.isIntersecting && !centeredPlayed) {
            centeredPlayed = true;
            try { v.currentTime = 0.5; } catch(e) {}
            window.__playNoScroll(v);
            cio.disconnect();
          }
        });
      }, { rootMargin: '-45% 0px -45% 0px', threshold: 0 });
      cio.observe(v);
      let tailDone = false;
      v.addEventListener('ended', () => {
        if (tailDone) return; tailDone = true;
        try { v.currentTime = 0; } catch(e) {}
        window.__playNoScroll(v);
        setTimeout(() => { try { v.pause(); } catch(e) {} }, 520);
      });
      v.style.cursor = 'pointer';
      v.addEventListener('click', () => {
        tailDone = false;
        try { v.currentTime = 0; } catch(e) {}
        window.__playNoScroll(v);
      });
    })();
  </script>
</body>
</html>
