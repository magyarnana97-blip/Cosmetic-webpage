// v3 — Futurisztikus prototípus (mobil-fókusz). Cím: /v3
---

<!DOCTYPE html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Szépségterapeuta — a tudomány ereje, a természet intelligenciája." />
  <title>szépségterapeuta — v3</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <script>
    if (window.location.hash) {
      history.replaceState(null, '', window.location.pathname + window.location.search);
    }
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
    if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  </script>
</head>

<body>
  <!-- ░ FEJLÉC ░ -->
  <header class="nav">
    <a href="/v3" class="brand" aria-label="Főoldal">
      <img src="/logo.png" alt="" class="brand-mark" />
      <span class="brand-name"><b>szépség</b>terapeuta</span>
    </a>
    <div class="nav-right">
      <a href="#kapcsolat" class="btn-book">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4.5" width="18" height="17" rx="2.5"/><path d="M3 9h18M8 2.5v4M16 2.5v4" stroke-linecap="round"/></svg>
        <span>Időpont</span>
      </a>
      <button class="burger" id="burger" aria-label="Menü"><span></span><span></span><span></span></button>
    </div>
  </header>
  <nav class="drawer" id="drawer">
    <a href="#kezelesek">Kezelések</a><a href="#rolam">Rólam</a><a href="#kapcsolat">Kapcsolat</a>
  </nav>

  <!-- ░ HERO ░ -->
  <section class="hero">
    <div class="hero-media">
      <!-- autoplay + muted + playsinline: böngésző feltétele; loop NINCS — egyszer játszik le -->
      <video class="hero-video" autoplay muted playsinline preload="auto" poster="/video-2-poster.jpg">
        <source src="/video-2.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="hero-left-fade" aria-hidden="true"></div>
    <div class="hero-text">
      <span class="eyebrow reveal">Professzionális<br/>bőrápolás</span>
      <svg class="brush reveal d1" viewBox="0 0 200 10" preserveAspectRatio="none" aria-hidden="true">
        <defs><linearGradient id="brushgrad" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0" stop-color="#8FAE52"/><stop offset=".28" stop-color="#A8C96A"/><stop offset=".62" stop-color="#ffffff"/><stop offset="1" stop-color="#ffffff" stop-opacity=".5"/>
        </linearGradient></defs>
        <path d="M1,2.6 L199,4.2 L199,5.6 L1,7.4 Z" fill="url(#brushgrad)"/>
      </svg>
      <h1 class="reveal d1">A tudomány<br/>ereje.<br/>A természet<br/><em>intelligenciája.</em></h1>
      <p class="lead reveal d2">Személyre szabott kezelések a bőröd egészségéért és ragyogásáért.</p>
      <div class="hero-cta reveal d3">
        <a href="#kapcsolat" class="btn-cut"><span class="lbl">Időpontot foglalok
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span></a>
        <a href="#kezelesek" class="link-play">
          <span class="play"><svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
          <span>Ismerd meg a<br/>kezeléseket</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ░ KÁRTYÁK ░ -->
  <section class="cards-band">
    <div class="cards">
      <div class="card-ic ic1" aria-hidden="true">
        <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" class="card-svg">
          <polygon points="28,16 36.66,21 36.66,31 28,36 19.34,31 19.34,21" stroke="currentColor" stroke-width="2.2" fill="none"/>
          <line x1="28" y1="16" x2="28" y2="7" stroke="currentColor" stroke-width="2.2"/>
          <circle cx="28" cy="5.5" r="2.2" fill="currentColor"/>
          <line x1="36.66" y1="21" x2="43.5" y2="17.1" stroke="currentColor" stroke-width="2.2"/>
          <circle cx="45.2" cy="16.1" r="2.2" fill="currentColor"/>
          <line x1="36.66" y1="31" x2="43.5" y2="34.9" stroke="currentColor" stroke-width="2.2"/>
          <circle cx="45.2" cy="36" r="2.2" fill="currentColor"/>
          <line x1="28" y1="36" x2="28" y2="45" stroke="currentColor" stroke-width="2.2"/>
          <circle cx="28" cy="46.5" r="2.2" fill="currentColor"/>
          <line x1="19.34" y1="31" x2="12.5" y2="34.9" stroke="currentColor" stroke-width="2.2"/>
          <circle cx="10.8" cy="36" r="2.2" fill="currentColor"/>
          <line x1="19.34" y1="21" x2="12.5" y2="17.1" stroke="currentColor" stroke-width="2.2"/>
          <circle cx="10.8" cy="16.1" r="2.2" fill="currentColor"/>
        </svg>
      </div>
      <div class="card-ic ic2" aria-hidden="true">
        <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" class="card-svg">
          <path d="M10,20 L10,10 L20,10" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <path d="M36,10 L46,10 L46,20" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <path d="M46,36 L46,46 L36,46" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <path d="M20,46 L10,46 L10,36" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <circle cx="28" cy="28" r="7.5" stroke="currentColor" stroke-width="2.2" fill="none"/>
          <circle cx="28" cy="28" r="2.4" fill="currentColor"/>
          <path d="M40,8 L44,8 L44,12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <line x1="40" y1="12" x2="44" y2="8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="card-ic ic3" aria-hidden="true">
        <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" class="card-svg">
          <path d="M10,23 C15,18 21,18 28,23 C35,28 41,28 46,23" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" fill="none"/>
          <path d="M10,32 C15,27 21,27 28,32 C35,37 41,37 46,32" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" fill="none"/>
          <line x1="13" y1="13" x2="13" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="11" y1="15" x2="15" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="42" y1="11" x2="42" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="40" y1="13" x2="44" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <circle cx="14" cy="43" r="1.8" fill="currentColor"/>
          <line x1="43" y1="41" x2="43" y2="45" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="41" y1="43" x2="45" y2="43" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="card reveal"><h3>Tudományos<br/>háttér</h3><p>Bizonyított hatóanyagok, látható eredmények.</p></div>
      <div class="card reveal d1"><h3>Személyre<br/>szabott kezelés</h3><p>Mert minden bőr egyedi.</p></div>
      <div class="card reveal d2"><h3>Prémium<br/>élmény</h3><p>Modern technológia, maximális kényelem.</p></div>
    </div>
  </section>

  <!-- ░ FEJLESZTÜNK ░ -->
  <section class="develop" id="rolam">
    <div class="develop-text">
      <span class="eyebrow reveal">A bőröd megérdemli</span>
      <h2 class="reveal d1">Nem csak kezelünk.<br/><em>Fejlesztünk.</em></h2>
      <svg class="brush brush-dev reveal d1" viewBox="0 0 200 10" preserveAspectRatio="none" aria-hidden="true">
        <path d="M1,2.6 L199,4.2 L199,5.6 L1,7.4 Z" fill="url(#brushgrad)"/>
      </svg>
      <p class="reveal d2">Együttműködünk a bőröddel, hogy hosszú távon a legjobb önmagad lehess.</p>
      <a href="#kapcsolat" class="btn-outline reveal d3">Kérj konzultációt
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
    <div class="serum reveal-media" id="serumWrap">
      <video id="dropvid" muted playsinline preload="auto" poster="/drop2-poster.jpg">
        <source src="/drop2.mp4" type="video/mp4" />
      </video>
    </div>
  </section>

  <!-- ░ ZÁRÓ CTA ░ -->
  <section class="closing" id="kezelesek">
    <div class="closing-inner reveal">
      <h2>Kezdjük el együtt</h2>
      <p>Az első konzultáció ingyenes. Találjuk meg a bőrödnek leginkább megfelelő, természetes kezelést.</p>
      <a href="#kapcsolat" class="btn-solid">Foglalj időpontot</a>
    </div>
  </section>

  <!-- ░ LÁBLÉC ░ -->
  <footer class="foot" id="kapcsolat">
    <img src="/logo.png" alt="" class="foot-mark" />
    <p class="foot-name"><b>szépség</b>terapeuta</p>
    <p class="foot-tag">A tudomány ereje, a természet intelligenciája.</p>
    <p class="foot-copy">© 2026 szépségterapeuta · Budapest</p>
  </footer>

  <style is:global>
    :root{
      --bg:#F2F4EF; --green:#A8C96A; --green-deep:#8FAE52; --soft:#C6DAB2;
      --box:#E8EAE2; --line:#D6D9CF; --muted:#7B8180; --ink:#3A3F3E;
      --serif:'Playfair Display',Georgia,serif; --sans:'Inter',system-ui,sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0;}
    html{
      scroll-behavior:smooth;
      overflow-x:hidden;
      overscroll-behavior-x:none;
      width:100%;
      max-width:100%;
    }
    body{
      font-family:var(--sans);background:var(--bg);color:var(--ink);font-weight:300;
      -webkit-font-smoothing:antialiased;
      overflow-x:hidden;
      overscroll-behavior-x:none;
      width:100%;
      max-width:100vw;
      position:relative;
      touch-action:pan-y;
    }
    h1,h2,h3{font-family:var(--serif);font-weight:400;line-height:1.08;color:var(--ink);}
    em{font-style:italic;color:var(--green);}
    img{max-width:100%;display:block;}
    a{text-decoration:none;color:inherit;}
    .reveal,.reveal-media{opacity:0;transform:translateY(30px);filter:blur(5px);transition:opacity 1s cubic-bezier(.22,1,.36,1),transform 1s cubic-bezier(.22,1,.36,1),filter 1s cubic-bezier(.22,1,.36,1);}
    .reveal.in,.reveal-media.in{opacity:1;transform:none;filter:blur(0);}
    .d1{transition-delay:.1s;} .d2{transition-delay:.2s;} .d3{transition-delay:.3s;}

    /* FEJLÉC */
    .nav{position:fixed;top:0;left:0;right:0;z-index:50;height:62px;display:flex;align-items:center;justify-content:space-between;padding:0 .85rem;background:rgba(242,244,239,.9);backdrop-filter:blur(12px);gap:.5rem;}
    .brand{display:flex;align-items:center;gap:.45rem;min-width:0;}
    .brand-mark{height:31px;width:auto;flex-shrink:0;}
    .brand-name{font-size:.9rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .brand-name b{font-weight:600;color:var(--green);}
    .nav-right{display:flex;align-items:center;gap:.55rem;flex-shrink:0;}
    .btn-book{display:flex;align-items:center;gap:.4rem;background:var(--green);color:#fff;font-size:.68rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;padding:.55rem .85rem;border-radius:9px;}
    .btn-book:hover{background:var(--green-deep);}
    .burger{display:flex;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:5px;}
    .burger span{width:25px;height:2px;background:var(--ink);transition:.3s;}
    .burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .burger.open span:nth-child(2){opacity:0;}
    .burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .drawer{position:fixed;top:64px;right:0;z-index:49;background:#fff;box-shadow:0 18px 44px rgba(58,63,62,.13);border-radius:0 0 0 14px;display:flex;flex-direction:column;padding:.4rem 0;transform:translateX(115%);transition:transform .4s cubic-bezier(.22,1,.36,1);}
    .drawer.open{transform:translateX(0);}
    .drawer a{padding:.85rem 2.4rem .85rem 1.6rem;font-size:.78rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;}
    .drawer a:hover{color:var(--green);background:var(--bg);}

    /* HERO */
    .hero{position:relative;height:560px;margin-top:44px;overflow:hidden;background:var(--bg);}
    .hero-media{position:absolute;top:1px;left:76px;width:80%;height:555px;border-radius:18px;overflow:hidden;background:linear-gradient(165deg,#eef0ea,#d6e2c8);}
    .hero-video{width:100%;height:100%;object-fit:cover;display:block;}
    .hero-left-fade{position:absolute;inset:0;z-index:2;pointer-events:none;background:linear-gradient(to right,var(--bg) 24%,rgba(242,244,239,.45) 46%,transparent 68%);}
    .hero-text{position:absolute;top:0;left:0;z-index:3;transform:translate(12px,56px) scale(.82);transform-origin:top left;width:78%;padding:0 1.1rem;}
    .eyebrow{display:block;font-size:.64rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--green);margin-bottom:.9rem;line-height:1.6;}
    .hero-text h1{font-size:clamp(1.8rem,7.6vw,2.3rem);margin-bottom:.9rem;}
    .lead{color:var(--muted);font-size:.82rem;line-height:1.6;max-width:230px;margin-bottom:1.4rem;}
    .hero-cta{display:flex;align-items:center;gap:.8rem;flex-wrap:nowrap;}
    .btn-cut{display:inline-flex;background:conic-gradient(from 200deg at 50% 50%,rgba(168,201,106,0.12) 0%,rgba(168,201,106,0.5) 20%,#A8C96A 40%,#8FAE52 50%,#A8C96A 60%,rgba(168,201,106,0.4) 80%,rgba(168,201,106,0.12) 100%);clip-path:polygon(9px 0,100% 0,100% calc(100% - 9px),calc(100% - 9px) 100%,0 100%,0 9px);transition:.3s;flex-shrink:0;}
    .btn-cut .lbl{display:inline-flex;align-items:center;gap:.45rem;white-space:nowrap;margin:1.5px;background:var(--bg);clip-path:polygon(8px 0,100% 0,100% calc(100% - 8px),calc(100% - 8px) 100%,0 100%,0 8px);color:var(--ink);font-size:.6rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:.75rem .95rem;transition:.3s;}
    .btn-cut:hover .lbl{background:var(--ink);color:#fff;}
    .link-play{display:inline-flex;align-items:center;gap:.5rem;white-space:nowrap;font-size:.56rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);line-height:1.35;}
    .play{width:32px;height:32px;border-radius:50%;border:1.5px solid var(--green);color:var(--green);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:.3s;}
    .link-play:hover .play{background:var(--green);color:#fff;}

    /* KÁRTYÁK */
    .cards-band{padding:1.4rem 1rem 2rem;margin-top:0;position:relative;z-index:5;}
    .cards{position:relative;--cpad:6px;--cardline:68%;background:rgba(20,23,21,0.35);backdrop-filter:blur(3px);-webkit-backdrop-filter:blur(3px);border:1px solid rgba(255,255,255,0.22);border-radius:20px;padding:var(--cpad) .85rem;display:grid;grid-template-columns:repeat(3,1fr);gap:.35rem;margin:0;transform:translate(-1px,-224px);box-shadow:0 26px 54px -26px rgba(0,0,0,.4);}
    .card{text-align:center;padding:54px .35rem .5rem;position:relative;}
    .card:not(:last-child)::after{content:'';position:absolute;right:0;top:calc((100% - var(--cardline))/2);height:var(--cardline);width:1.5px;background:rgba(255,255,255,.6);}
    .card-ic{position:absolute;top:8px;left:50%;z-index:3;display:flex;align-items:center;justify-content:center;color:var(--green);}
    .card-svg{display:block;}
    .ic1{width:46px;height:46px;transform:translate(-50%,0) translate(-115px,2px);}
    .ic1 .card-svg{width:46px;height:46px;}
    .ic2{width:52px;height:52px;transform:translate(-50%,0) translate(-1px,-3px);}
    .ic2 .card-svg{width:52px;height:52px;}
    .ic3{width:52px;height:52px;transform:translate(-50%,0) translate(112px,-3px);}
    .ic3 .card-svg{width:52px;height:52px;}
    .card h3{font-size:.74rem;letter-spacing:.05em;text-transform:uppercase;font-family:var(--sans);font-weight:500;color:#fff;margin-bottom:.5rem;line-height:1.3;}
    .card p{color:rgba(255,255,255,.78);font-size:.7rem;line-height:1.5;}

    /* FEJLESZTÜNK */
    .brush{display:block;width:59px;height:9px;margin:.15rem 0 .8rem;}
    .brush-dev{width:65px;margin:.1rem 0 1rem;}

    /* SÉRUM */
    .serum{position:absolute;left:105px;top:-305px;z-index:0;width:70%;}
    .serum video{
      width:100%;display:block;
      filter:saturate(3.2) brightness(1.05) hue-rotate(-12deg);
      transform:translateZ(0);
      will-change:transform;
      -webkit-mask-image:radial-gradient(98% 92% at 50% 46%,#000 14%,transparent 60%);
      mask-image:radial-gradient(98% 92% at 50% 46%,#000 14%,transparent 60%);
    }
    .btn-outline{display:inline-flex;align-items:center;gap:.5rem;border:1.5px solid var(--green);color:var(--ink);font-size:.72rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;padding:.7rem 1.2rem;border-radius:10px;transition:.3s;}
    .btn-outline:hover{background:var(--green);color:#fff;}
    .develop{position:relative;padding:1.5rem 1.4rem 2rem;overflow:visible;min-height:90px;margin-top:0;}
    .develop-text{position:absolute;transform:translate(4px,-264px) scale(.70);transform-origin:top left;width:70%;z-index:2;}
    .develop-text h2{font-size:clamp(2rem,8vw,2.6rem);margin-bottom:1rem;}
    .develop-text p{color:var(--muted);font-size:.95rem;line-height:1.7;max-width:300px;margin-bottom:1.6rem;}

    /* ZÁRÓ */
    .closing{padding:1rem 1.1rem 2.4rem;}
    .closing-inner{text-align:center;background:var(--ink);color:#fff;border-radius:22px;padding:2.6rem 1.6rem;}
    .closing-inner h2{color:#fff;font-size:1.9rem;margin-bottom:.8rem;}
    .closing-inner p{color:rgba(255,255,255,.78);font-size:.9rem;margin:0 auto 1.6rem;line-height:1.65;}
    .btn-solid{display:inline-block;background:var(--green);color:#fff;font-size:.76rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:.9rem 1.8rem;border-radius:11px;}
    .btn-solid:hover{background:var(--green-deep);}

    /* LÁBLÉC */
    .foot{text-align:center;padding:2.6rem 1.5rem 3rem;}
    .foot-mark{height:42px;width:auto;margin:0 auto .7rem;}
    .foot-name{font-size:1.05rem;color:var(--muted);}
    .foot-name b{color:var(--green);font-weight:600;}
    .foot-tag{font-family:var(--serif);font-style:italic;color:var(--muted);font-size:.9rem;margin:.5rem 0 1.2rem;}
    .foot-copy{font-size:.72rem;color:var(--muted);opacity:.7;}

    @media (min-width:760px){
      .hero-text{max-width:1100px;margin:0 auto;padding-bottom:4rem;}
      .cards,.develop,.closing-inner{max-width:1000px;margin-left:auto;margin-right:auto;}
      .lead,.develop-text p{max-width:420px;}
    }
  </style>

  <script>
    window.addEventListener('pageshow', () => {
      window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
    });

    // ---- HERO VIDEÓ: egyszer játszik le, egyenletesen 0.85x ----
    (() => {
      const hv = document.querySelector('.hero-video');
      if (!hv) return;
      const setRate = () => { hv.playbackRate = 0.85; };
      hv.addEventListener('loadedmetadata', setRate);
      hv.addEventListener('play', setRate);
      setRate();
    })();

    // ---- BURGER MENÜ ----
    const burger = document.getElementById('burger');
    const drawer = document.getElementById('drawer');
    burger?.addEventListener('click', () => {
      burger.classList.toggle('open');
      drawer?.classList.toggle('open');
    });
    drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      burger?.classList.remove('open');
      drawer.classList.remove('open');
    }));

    // ---- REVEAL ANIMÁCIÓ ----
    const io = new IntersectionObserver((es) => es.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    }), { threshold: .12 });
    document.querySelectorAll('.reveal, .reveal-media').forEach(el => {
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight * 1.05) {
        el.classList.add('in');
      } else {
        io.observe(el);
      }
    });

    // ---- SÉRUM VIDEÓ: egyszer játszik, az utolsó kockán megáll, kattintásra újraindul ----
    (() => {
      const v = document.getElementById('dropvid');
      if (!v) return;
      const sec = document.querySelector('.develop');
      let started = false;

      const vio = new IntersectionObserver((es) => {
        es.forEach(e => {
          if (e.isIntersecting && !started) {
            started = true;
            try { v.currentTime = 0; const p = v.play(); if (p && p.catch) p.catch(() => {}); } catch(err) {}
            vio.disconnect();
          }
        });
      }, { threshold: .35 });
      vio.observe(sec);

      v.style.cursor = 'pointer';
      v.addEventListener('click', () => {
        try { v.currentTime = 0; const p = v.play(); if (p && p.catch) p.catch(() => {}); } catch(err) {}
      });
    })();
  </script>
</body>
</html>
