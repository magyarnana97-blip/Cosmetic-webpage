---
// v3 — Futurisztikus prototípus (mobil-fókusz). Cím: /v3
// Az oldal SZEKCIÓNKÉNT külön komponensekből áll össze (lásd src/components/*).
// Így minden rész önállóan, biztonságosan szerkeszthető — a hero nem sérül más szekciók módosításakor.
import '../../styles/global.css';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Kartyak from '../../components/Kartyak.astro';
import Fejlesztunk from '../../components/Fejlesztunk.astro';
import Kezelesek from '../../components/Kezelesek.astro';
import Rolam from '../../components/Rolam.astro';
import Boreelemzes from '../../components/Boreelemzes.astro';
import Zaro from '../../components/Zaro.astro';
import Footer from '../../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Szépségterapeuta — a tudomány ereje, a természet intelligenciája." />
  <title>szépségterapeuta — v3</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>

<body>
  <Nav />
  <Hero />
  <Kartyak />
  <Fejlesztunk />
  <Kezelesek />
  <Rolam />
  <Boreelemzes />
  <Zaro />
  <Footer />

  <script>
    // a böngésző ne állítsa vissza a korábbi görgetés-pozíciót (sima reload a tetejéről indul)
    if('scrollRestoration' in history) history.scrollRestoration='manual';
    // BIZTOSÍTÉK: betöltéskor MINDIG a tetejére (még ha egy autoplay videó próbálna is odagörgetni)
    window.scrollTo(0,0);
    window.addEventListener('load', function(){ window.scrollTo(0,0); setTimeout(function(){ window.scrollTo(0,0); }, 60); });

    // Bármely videó lejátszása ÚGY, hogy a böngésző NE görgessen hozzá (megőrzi a pozíciódat)
    window.__playNoScroll = function(v){
      const sy = window.scrollY;
      try{ const p = v.play(); if(p&&p.catch) p.catch(()=>{}); }catch(e){}
      const fix = () => { if(Math.abs(window.scrollY - sy) > 2) window.scrollTo(0, sy); };
      requestAnimationFrame(fix); setTimeout(fix, 40); setTimeout(fix, 120);
    };

    // HERO videó: autoplay (a markupban indítja a böngésző), itt csak a sebesség 0.85x — egyszer beállítva, nem akad
    (() => {
      const hv = document.querySelector('.hero-video');
      if(!hv) return;
      const setRate = () => { hv.playbackRate = 0.85; };
      hv.addEventListener('loadedmetadata', setRate);
      hv.addEventListener('play', setRate);
      setRate();
    })();

    // GÖMB videó (Kezelések fejléc): no-scroll lejátszás, hogy betöltéskor NE ugorjon az oldal középre
    (() => {
      const ov = document.querySelector('.kz-orb-vid');
      if(!ov) return;
      const play = () => window.__playNoScroll(ov);
      if(ov.readyState >= 2) play(); else ov.addEventListener('loadeddata', play, { once:true });
    })();

    const burger=document.getElementById('burger'),drawer=document.getElementById('drawer');
    burger?.addEventListener('click',()=>{burger.classList.toggle('open');drawer?.classList.toggle('open');});
    drawer?.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{burger?.classList.remove('open');drawer.classList.remove('open');}));
    const io=new IntersectionObserver((es)=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}}),{threshold:.12});
    document.querySelectorAll('.reveal,.reveal-media').forEach(el=>io.observe(el));

    // SZÉRUM VIDEÓ:
    //  - betöltéskor azonnal lefut 0,5 mp (teaser), majd megáll a 0,5-nél
    //  - amikor a videó a KÉPERNYŐ KÖZEPÉN van, lejátssza a többit (0,5 mp -> vége)
    (() => {
      const v = document.getElementById('dropvid');
      if(!v) return;
      let teased = false, centeredPlayed = false;
      const teaser = () => {
        if(teased) return; teased = true;
        try{ v.currentTime = 0; }catch(e){}
        window.__playNoScroll(v);
        setTimeout(() => { try{ if(!centeredPlayed){ v.pause(); v.currentTime = 0.5; } }catch(e){} }, 500);
      };
      if(v.readyState >= 2) teaser(); else v.addEventListener('loadeddata', teaser, { once:true });
      // a viewport középső ~10% sávjában: lejátssza a többit (görgetés-védelemmel)
      const cio = new IntersectionObserver((es) => {
        es.forEach(e => {
          if(e.isIntersecting && !centeredPlayed){
            centeredPlayed = true;
            try{ v.currentTime = 0.5; }catch(e){}
            window.__playNoScroll(v);
            cio.disconnect();
          }
        });
      }, { rootMargin: '-45% 0px -45% 0px', threshold: 0 });
      cio.observe(v);
      // amikor lefutott a videó, lejátssza még az ELSŐ 0,5 mp-et, majd megáll
      let tailDone = false;
      v.addEventListener('ended', () => {
        if(tailDone) return; tailDone = true;
        try{ v.currentTime = 0; }catch(e){}
        window.__playNoScroll(v);
        setTimeout(() => { try{ v.pause(); }catch(e){} }, 520);
      });
      // kattintásra újraindul az elejéről (a "farok" is újra lejátszódhat)
      v.style.cursor = 'pointer';
      v.addEventListener('click', () => { tailDone = false; try{ v.currentTime = 0; }catch(e){} window.__playNoScroll(v); });
    })();
  </script>
</body>
</html>
