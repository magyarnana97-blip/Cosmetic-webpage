---
// v3 — Futurisztikus prototípus (mobil-fókusz). Cím: /v3
// A HERO arc helye SZÁNDÉKOSAN üres (háttérszín) — ide kerül majd a tiszta videó.
// A kártya-piktogramok helye is üres (csak a hely van meg).
---

<!DOCTYPE html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Szépségterapeuta — a tudomány ereje, a természet intelligenciája." />
  <title>szépségterapeuta — v3</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>

<body>
  <!-- ░ FEJLÉC ░ -->
  <header class="nav">
    <a href="/v3" class="brand" aria-label="Főoldal">
      <img src="/logo.png" alt="" class="brand-mark" />
      <span class="brand-name"><b>szépség</b>terapeuta</span>
    </a>
    <div class="nav-right">
      <a href="#kapcsolat" class="btn-book">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4.5" width="18" height="17" rx="2.5"/><path d="M3 9h18M8 2.5v4M16 2.5v4" stroke-linecap="round"/></svg>
        <span>Időpont</span>
      </a>
      <button class="burger" id="burger" aria-label="Menü"><span></span><span></span><span></span></button>
    </div>
  </header>
  <nav class="drawer" id="drawer">
    <a href="#kezelesek">Kezelések</a><a href="#rolam">Rólam</a><a href="#kapcsolat">Kapcsolat</a>
  </nav>

  <!-- ░ HERO ░ -->
  <section class="hero">
    <!-- NŐI VIDEÓ: auto-indul, némítva, nem ismétlődik, az utolsó kockán megáll -->
    <div class="hero-media">
      <video class="hero-video" autoplay muted playsinline preload="auto" poster="/video-2-poster.jpg">
        <source src="/video-2.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="hero-left-fade" aria-hidden="true"></div>

    <div class="hero-text">
      <span class="eyebrow reveal">Professzionális<br/>bőrápolás</span>
      <svg class="brush reveal d1" viewBox="0 0 200 22" preserveAspectRatio="none" aria-hidden="true">
        <defs><linearGradient id="brushgrad" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0" stop-color="#8FAE52"/><stop offset=".22" stop-color="#A8C96A"/><stop offset=".55" stop-color="#ffffff"/><stop offset="1" stop-color="#ffffff" stop-opacity=".5"/>
        </linearGradient></defs>
        <path d="M3,13 C36,5 64,18 104,11 C140,5 168,13 197,9" fill="none" stroke="url(#brushgrad)" stroke-width="4.5" stroke-linecap="round"/>
        <path d="M6,16 C40,10 66,19 100,14" fill="none" stroke="url(#brushgrad)" stroke-width="1.8" stroke-linecap="round" opacity=".5"/>
      </svg>
      <h1 class="reveal d1">A tudomány<br/>ereje.<br/>A természet<br/><em>intelligenciája.</em></h1>
      <p class="lead reveal d2">Személyre szabott kezelések a bőröd egészségéért és ragyogásáért.</p>
      <div class="hero-cta reveal d3">
        <a href="#kapcsolat" class="btn-cut"><span class="lbl">Időpontot foglalok
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span></a>
        <a href="#kezelesek" class="link-play">
          <span class="play"><svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
          <span>Ismerd meg a<br/>kezeléseket</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ░ KÁRTYÁK ░ -->
  <section class="cards-band">
    <div class="cards">
      <div class="card reveal">
        <span class="ic-slot" aria-hidden="true"></span>
        <h3>Tudományos<br/>háttér</h3>
        <p>Bizonyított hatóanyagok, látható eredmények.</p>
      </div>
      <div class="card reveal d1">
        <span class="ic-slot" aria-hidden="true"></span>
        <h3>Személyre<br/>szabott kezelés</h3>
        <p>Mert minden bőr egyedi.</p>
      </div>
      <div class="card reveal d2">
        <span class="ic-slot" aria-hidden="true"></span>
        <h3>Prémium<br/>élmény</h3>
        <p>Modern technológia, maximális kényelem.</p>
      </div>
    </div>
  </section>

  <!-- ░ FEJLESZTÜNK ░ -->
  <section class="develop" id="rolam">
    <div class="develop-text">
      <span class="eyebrow reveal">A bőröd megérdemli</span>
      <h2 class="reveal d1">Nem csak kezelünk.<br/><em>Fejlesztünk.</em></h2>
      <svg class="brush brush-dev reveal d1" viewBox="0 0 200 22" preserveAspectRatio="none" aria-hidden="true">
        <path d="M3,13 C36,5 64,18 104,11 C140,5 168,13 197,9" fill="none" stroke="url(#brushgrad)" stroke-width="4.5" stroke-linecap="round"/>
        <path d="M6,16 C40,10 66,19 100,14" fill="none" stroke="url(#brushgrad)" stroke-width="1.8" stroke-linecap="round" opacity=".5"/>
      </svg>
      <p class="reveal d2">Együttműködünk a bőröddel, hogy hosszú távon a legjobb önmagad lehess.</p>
      <a href="#kapcsolat" class="btn-outline reveal d3">Kérj konzultációt
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
    <!-- SZÉRUM VIDEÓ: betöltéskor 0,5 mp, majd görgetésre lejátszódik a teljes 3 mp -->
    <div class="serum reveal-media">
      <video id="dropvid" muted playsinline preload="auto" poster="/drop2-poster.jpg">
        <source src="/drop2.mp4" type="video/mp4" />
      </video>
    </div>
  </section>

  <!-- ░ ZÁRÓ CTA ░ -->
  <section class="closing" id="kezelesek">
    <div class="closing-inner reveal">
      <h2>Kezdjük el együtt</h2>
      <p>Az első konzultáció ingyenes. Találjuk meg a bőrödnek leginkább megfelelő, természetes kezelést.</p>
      <a href="#kapcsolat" class="btn-solid">Foglalj időpontot</a>
    </div>
  </section>

  <!-- ░ LÁBLÉC ░ -->
  <footer class="foot" id="kapcsolat">
    <img src="/logo.png" alt="" class="foot-mark" />
    <p class="foot-name"><b>szépség</b>terapeuta</p>
    <p class="foot-tag">A tudomány ereje, a természet intelligenciája.</p>
    <p class="foot-copy">© 2026 szépségterapeuta · Budapest</p>
  </footer>

  <style is:global>
    :root{
      --bg:#F2F4EF; --green:#A8C96A; --green-deep:#8FAE52; --soft:#C6DAB2;
      --box:#E8EAE2; --line:#D6D9CF; --muted:#7B8180; --ink:#3A3F3E;
      --serif:'Playfair Display',Georgia,serif; --sans:'Inter',system-ui,sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{font-family:var(--sans);background:var(--bg);color:var(--ink);font-weight:300;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
    h1,h2,h3{font-family:var(--serif);font-weight:400;line-height:1.08;color:var(--ink);}
    em{font-style:italic;color:var(--green);}
    img{max-width:100%;display:block;}
    a{text-decoration:none;color:inherit;}
    .reveal,.reveal-media{opacity:0;transform:translateY(30px);filter:blur(5px);transition:opacity 1s cubic-bezier(.22,1,.36,1),transform 1s cubic-bezier(.22,1,.36,1),filter 1s cubic-bezier(.22,1,.36,1);}
    .reveal.in,.reveal-media.in{opacity:1;transform:none;filter:blur(0);}
    .d1{transition-delay:.1s;} .d2{transition-delay:.2s;} .d3{transition-delay:.3s;}

    /* FEJLÉC */
    .nav{position:fixed;top:0;left:0;right:0;z-index:50;height:62px;display:flex;align-items:center;justify-content:space-between;padding:0 .85rem;background:rgba(242,244,239,.9);backdrop-filter:blur(12px);gap:.5rem;}
    .brand{display:flex;align-items:center;gap:.45rem;min-width:0;}
    .brand-mark{height:31px;width:auto;flex-shrink:0;}
    .brand-name{font-size:.9rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .brand-name b{font-weight:600;color:var(--green);}
    .nav-right{display:flex;align-items:center;gap:.55rem;flex-shrink:0;}
    .btn-book{display:flex;align-items:center;gap:.4rem;background:var(--green);color:#fff;font-size:.68rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;padding:.55rem .85rem;border-radius:9px;}
    .btn-book:hover{background:var(--green-deep);}
    .burger{display:flex;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:5px;}
    .burger span{width:25px;height:2px;background:var(--ink);transition:.3s;}
    .burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .burger.open span:nth-child(2){opacity:0;}
    .burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .drawer{position:fixed;top:64px;right:0;z-index:49;background:#fff;box-shadow:0 18px 44px rgba(58,63,62,.13);border-radius:0 0 0 14px;display:flex;flex-direction:column;padding:.4rem 0;transform:translateX(115%);transition:transform .4s cubic-bezier(.22,1,.36,1);}
    .drawer.open{transform:translateX(0);}
    .drawer a{padding:.85rem 2.4rem .85rem 1.6rem;font-size:.78rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;}
    .drawer a:hover{color:var(--green);background:var(--bg);}

    /* HERO */
    .hero{position:relative;height:560px;margin-top:62px;overflow:hidden;background:var(--bg);}
    .hero-media{position:absolute;top:1px;left:19.5%;width:80%;height:555px;border-radius:18px;overflow:hidden;background:linear-gradient(165deg,#eef0ea,#d6e2c8);}
    .hero-video{width:100%;height:100%;object-fit:cover;display:block;}
    .tech{position:absolute;top:6%;right:-6%;width:74%;height:auto;mix-blend-mode:screen;z-index:2;}
    .ring{transform-box:fill-box;transform-origin:center;}
    .r1{animation:spin 34s linear infinite;} .r2{animation:spin 24s linear infinite reverse;} .r3{animation:spin 48s linear infinite;}
    .nodes{animation:pulse 3.4s ease-in-out infinite;}
    @keyframes spin{to{transform:rotate(360deg);}}
    @keyframes pulse{0%,100%{opacity:.45;}50%{opacity:.85;}}
    /* felül krém (szöveghez), lent átlátszó (ott jön a nő) */
    .hero-left-fade{position:absolute;inset:0;z-index:2;pointer-events:none;background:linear-gradient(to right,var(--bg) 24%,rgba(242,244,239,.45) 46%,transparent 68%);}
    .hero-text{position:absolute;top:0;left:0;z-index:3;transform:translate(12px,56px) scale(.82);transform-origin:top left;width:78%;padding:0 1.1rem;}
    .eyebrow{display:block;font-size:.64rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--green);margin-bottom:.9rem;line-height:1.6;}
    .hero-text h1{font-size:clamp(1.8rem,7.6vw,2.3rem);margin-bottom:.9rem;}
    .lead{color:var(--muted);font-size:.82rem;line-height:1.6;max-width:230px;margin-bottom:1.4rem;}
    .hero-cta{display:flex;align-items:center;gap:.8rem;flex-wrap:nowrap;}
    /* levágott sarkú gomb */
    .btn-cut{display:inline-flex;background:linear-gradient(105deg,#8FAE52 0%,#A8C96A 15%,#ffffff 18%,#A8C96A 21%,#C6DAB2 44%,#ffffff 47%,#8FAE52 51%,#A8C96A 77%,#ffffff 80%,#8FAE52 83%,#A8C96A 100%);clip-path:polygon(9px 0,100% 0,100% calc(100% - 9px),calc(100% - 9px) 100%,0 100%,0 9px);transition:.3s;flex-shrink:0;}
    .btn-cut .lbl{display:inline-flex;align-items:center;gap:.45rem;white-space:nowrap;margin:1.5px;background:var(--bg);clip-path:polygon(8px 0,100% 0,100% calc(100% - 8px),calc(100% - 8px) 100%,0 100%,0 8px);color:var(--ink);font-size:.6rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:.75rem .95rem;transition:.3s;}
    .btn-cut:hover .lbl{background:var(--ink);color:#fff;}
    .link-play{display:inline-flex;align-items:center;gap:.5rem;white-space:nowrap;font-size:.56rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);line-height:1.35;}
    .play{width:32px;height:32px;border-radius:50%;border:1.5px solid var(--green);color:var(--green);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:.3s;}
    .link-play:hover .play{background:var(--green);color:#fff;}

    /* KÁRTYÁK */
    .cards-band{padding:1.6rem 1rem 2.4rem;margin-top:-225px;position:relative;z-index:5;}
    .cards{background:rgba(46,52,48,0.4);backdrop-filter:blur(3px);-webkit-backdrop-filter:blur(3px);border:1px solid rgba(255,255,255,0.22);border-radius:20px;padding:1.4rem .85rem;display:grid;grid-template-columns:repeat(3,1fr);gap:.35rem;margin:0 .7rem;transform:translateX(-5px);box-shadow:0 26px 54px -26px rgba(0,0,0,.4);}
    .card{text-align:center;padding:.5rem .35rem;position:relative;}
    .card:not(:last-child)::after{content:'';position:absolute;right:0;top:16%;height:68%;width:1.5px;background:rgba(255,255,255,.55);}
    .ic-slot{display:block;width:38px;height:38px;margin:0 auto .9rem;border-radius:10px;border:1px dashed rgba(255,255,255,.35);}
    .card h3{font-size:.74rem;letter-spacing:.05em;text-transform:uppercase;font-family:var(--sans);font-weight:500;color:#fff;margin-bottom:.5rem;line-height:1.3;}
    .card p{color:rgba(255,255,255,.78);font-size:.7rem;line-height:1.5;}

    /* FEJLESZTÜNK */
    /* ECSETVONÁS */
    .brush{display:block;width:118px;height:17px;margin:.15rem 0 .85rem;}
    .brush-dev{width:130px;margin:.1rem 0 1rem;}
    /* PIPETTA + CSEPP + HULLÁMZÁS */
    .serum{position:absolute;right:-8px;top:1.3rem;z-index:1;width:56%;}
    .serum video{width:100%;border-radius:14px;display:block;}
    .pool{fill:rgba(150,180,90,.26);}
    .ripple{fill:none;stroke:#9bbe66;stroke-width:1.6;transform-box:fill-box;transform-origin:center;animation:rippleout 3s ease-out infinite;}
    .ripple2{animation-delay:.32s;}
    .drop{transform-box:fill-box;transform-origin:center;animation:dropfall 3s cubic-bezier(.45,0,.9,.45) infinite;}
    @keyframes dropfall{0%{transform:translateY(0);opacity:0;}8%{opacity:1;}42%{transform:translateY(33px);opacity:1;}48%{transform:translateY(36px);opacity:0;}100%{transform:translateY(36px);opacity:0;}}
    @keyframes rippleout{0%,42%{transform:scale(.25);opacity:0;}50%{opacity:.7;}82%{transform:scale(2.3);opacity:0;}100%{opacity:0;}}
    @media (prefers-reduced-motion:reduce){.drop,.ripple,.r1,.r2,.r3,.nodes{animation:none;}}

    .develop{position:relative;padding:2.2rem 1.4rem 3rem;overflow:hidden;min-height:320px;}
    .develop-text{transform:translate(-11px,0) scale(.70);transform-origin:top left;width:64%;position:relative;z-index:2;}
    .develop-text h2{font-size:clamp(2rem,8vw,2.6rem);margin-bottom:1rem;}
    .develop-text p{color:var(--muted);font-size:.95rem;line-height:1.7;max-width:300px;margin-bottom:1.6rem;}
    .develop-media{position:relative;z-index:1;height:200px;margin-top:1.5rem;border-radius:18px;background:radial-gradient(120px 120px at 70% 45%,#cfe0a8,#aecb7e 60%,#9bbe66 100%);box-shadow:0 30px 60px -28px rgba(110,132,103,.5);}
    .green-texture{position:absolute;left:0;right:0;bottom:0;height:190px;z-index:0;background:
      radial-gradient(140% 90px at 50% 100%,rgba(168,201,106,.45),transparent 70%),
      repeating-linear-gradient(115deg,rgba(150,180,90,.16) 0 2px,transparent 2px 16px);
      pointer-events:none;}

    /* ZÁRÓ */
    .closing{padding:1rem 1.1rem 2.4rem;}
    .closing-inner{text-align:center;background:var(--ink);color:#fff;border-radius:22px;padding:2.6rem 1.6rem;}
    .closing-inner h2{color:#fff;font-size:1.9rem;margin-bottom:.8rem;}
    .closing-inner p{color:rgba(255,255,255,.78);font-size:.9rem;margin:0 auto 1.6rem;line-height:1.65;}
    .btn-solid{display:inline-block;background:var(--green);color:#fff;font-size:.76rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:.9rem 1.8rem;border-radius:11px;}
    .btn-solid:hover{background:var(--green-deep);}

    /* LÁBLÉC */
    .foot{text-align:center;padding:2.6rem 1.5rem 3rem;}
    .foot-mark{height:42px;width:auto;margin:0 auto .7rem;}
    .foot-name{font-size:1.05rem;color:var(--muted);}
    .foot-name b{color:var(--green);font-weight:600;}
    .foot-tag{font-family:var(--serif);font-style:italic;color:var(--muted);font-size:.9rem;margin:.5rem 0 1.2rem;}
    .foot-copy{font-size:.72rem;color:var(--muted);opacity:.7;}

    /* nagyobb képernyőn középre fogjuk, de a fókusz a mobil */
    @media (min-width:760px){
      .hero-text{max-width:1100px;margin:0 auto;padding-bottom:4rem;}
      .cards,.develop,.closing-inner{max-width:1000px;margin-left:auto;margin-right:auto;}
      .lead,.develop-text p{max-width:420px;}
    }
  </style>

  <script>
    // mindig a tetejéről induljon (ne ugorjon a lap közepére)
    if('scrollRestoration' in history) history.scrollRestoration='manual';
    window.scrollTo(0,0);
    window.addEventListener('load',()=>window.scrollTo(0,0));

    const burger=document.getElementById('burger'),drawer=document.getElementById('drawer');
    burger?.addEventListener('click',()=>{burger.classList.toggle('open');drawer?.classList.toggle('open');});
    drawer?.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{burger?.classList.remove('open');drawer.classList.remove('open');}));
    const io=new IntersectionObserver((es)=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}}),{threshold:.12});
    document.querySelectorAll('.reveal,.reveal-media').forEach(el=>io.observe(el));

    // SZÉRUM VIDEÓ: betöltéskor 0,5 mp lejátszás, utána görgetésre pörgetjük (0,5s → 3s)
    (() => {
      const v = document.getElementById('dropvid');
      if(!v) return;
      const sec = document.querySelector('.develop');
      let scrub = false, ticking = false;
      const startIntro = () => {
        try { v.currentTime = 0; const p = v.play(); if(p&&p.catch) p.catch(()=>{}); } catch(e){}
        setTimeout(() => { try{ v.pause(); }catch(e){} scrub = true; }, 500);
      };
      v.addEventListener('loadeddata', startIntro, { once:true });
      const update = () => {
        if(scrub && sec){
          const r = sec.getBoundingClientRect();
          const vh = window.innerHeight || 800;
          let p = (vh - r.top) / vh;            // 0 amikor belép alulról, 1 amikor a teteje fent
          p = Math.min(Math.max(p, 0), 1);
          const t = 0.5 + p * 2.5;              // 0,5s → 3,0s
          if(Number.isFinite(t)) { try{ v.currentTime = Math.min(t, (v.duration||3) - 0.05); }catch(e){} }
        }
        ticking = false;
      };
      window.addEventListener('scroll', () => { if(!ticking){ requestAnimationFrame(update); ticking = true; } }, { passive:true });
    })();
  </script>
</body>
</html>
