---
import type { Locale } from '../i18n/utils';
import { getSection, localePath, SUPPORTED_LOCALES } from '../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description: string;
}

const { locale, title, description } = Astro.props;
const nav = getSection<any>(locale, 'nav');
const footer = getSection<any>(locale, 'footer');

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BeautySalon',
  name: 'Hancz Marianna Szépségterapeuta',
  url: 'https://szepsegterapeuta.hu',
  telephone: '+36-20-339-3399',
  email: 'info@szepsegterapeuta.hu',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Dolgos utca 2. 6B lépcsőház',
    addressLocality: 'Budapest',
    postalCode: '1126',
    addressCountry: 'HU'
  },
  openingHours: 'Mo-Su 06:00-20:00',
  description
});
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="canonical" href={`https://szepsegterapeuta.hu${localePath(locale)}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={schema} />
</head>
<body>

  <header class="site-nav">
    <div class="nav-wrap">
      <a href={localePath(locale)} class="nav-logo">
        <img src="/logo.svg" alt="Szépségterapeuta" width="160" height="44" />
      </a>
      <nav>
        <ul>
          <li><a href={`${localePath(locale)}#services`}>{nav.services}</a></li>
          <li><a href={`${localePath(locale)}#about`}>{nav.about}</a></li>
          <li><a href={`${localePath(locale)}#contact`}>{nav.contact}</a></li>
        </ul>
      </nav>
      <div class="nav-end">
        <div class="lang-row">
          {SUPPORTED_LOCALES.map(l => (
            <a href={localePath(l)} class={`lbtn${l === locale ? ' on' : ''}`} hreflang={l}>
              {l.toUpperCase()}
            </a>
          ))}
        </div>
        <a href={`${localePath(locale)}#contact`} class="cta-pill">{nav.book}</a>
      </div>
    </div>
  </header>

  <main><slot /></main>

  <footer class="site-footer">
    <p class="ft-quote">{footer.tagline}</p>
    <p class="ft-copy">{footer.copyright}</p>
  </footer>

</body>
</html>

<style is:global>
  :root {
    --c-gold:    #B89A6A;
    --c-sage:    #7A8C72;
    --c-cream:   #FAF8F4;
    --c-linen:   #F0EBE1;
    --c-stone:   #E8E0D2;
    --c-ink:     #1E1E1E;
    --c-muted:   #767068;
    --f-serif:   'Cormorant Garamond', Georgia, serif;
    --f-sans:    'Jost', system-ui, sans-serif;
    --mw:        1160px;
    --ease:      0.35s ease;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; font-size: 16px; }
  body {
    font-family: var(--f-sans);
    font-weight: 300;
    background: var(--c-cream);
    color: var(--c-ink);
    line-height: 1.75;
    -webkit-font-smoothing: antialiased;
  }
  h1, h2, h3, h4 {
    font-family: var(--f-serif);
    font-weight: 400;
    line-height: 1.2;
  }
  img { max-width: 100%; height: auto; display: block; }
  a { color: inherit; }

  /* ── NAV ─────────────────────────────── */
  .site-nav {
    position: sticky; top: 0; z-index: 200;
    background: rgba(250,248,244,0.94);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--c-stone);
  }
  .nav-wrap {
    max-width: var(--mw); margin: 0 auto;
    padding: 0.9rem 2rem;
    display: flex; align-items: center; gap: 2.5rem;
  }
  .nav-logo { flex-shrink: 0; text-decoration: none; }
  nav ul { list-style: none; display: flex; gap: 2.5rem; }
  nav a {
    text-decoration: none;
    font-size: 0.82rem; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--c-muted);
    transition: color var(--ease);
  }
  nav a:hover { color: var(--c-ink); }
  .nav-end { margin-left: auto; display: flex; align-items: center; gap: 1.25rem; }

  /* Nyelvváltó */
  .lang-row { display: flex; gap: 0.15rem; }
  .lbtn {
    font-family: var(--f-sans); font-size: 0.7rem; font-weight: 500;
    letter-spacing: 0.08em; text-decoration: none;
    color: var(--c-muted); padding: 0.3rem 0.5rem;
    border-radius: 3px; transition: all var(--ease);
  }
  .lbtn:hover { color: var(--c-ink); }
  .lbtn.on { color: var(--c-gold); font-weight: 500; }

  /* CTA gomb */
  .cta-pill {
    display: inline-block; text-decoration: none;
    background: var(--c-gold); color: #fff;
    font-family: var(--f-sans); font-size: 0.78rem;
    font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.7rem 1.8rem; border-radius: 2px;
    transition: background var(--ease), transform var(--ease);
    border: none; cursor: pointer; white-space: nowrap;
  }
  .cta-pill:hover { background: var(--c-sage); transform: translateY(-1px); }

  .cta-ghost {
    display: inline-block; text-decoration: none;
    background: transparent; color: var(--c-ink);
    font-family: var(--f-sans); font-size: 0.78rem;
    font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.7rem 1.8rem; border-radius: 2px;
    border: 1px solid var(--c-ink);
    transition: all var(--ease);
  }
  .cta-ghost:hover { background: var(--c-ink); color: #fff; }

  /* Szekciók */
  .sec { padding: clamp(4rem, 9vw, 9rem) 2rem; }
  .sec-inner { max-width: var(--mw); margin: 0 auto; }
  .sec-label {
    display: block; font-family: var(--f-sans);
    font-size: 0.68rem; font-weight: 500; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--c-gold);
    margin-bottom: 1rem;
  }
  .sec-head { text-align: center; margin-bottom: 4rem; }
  .sec-head h2 { font-size: clamp(2rem, 4.5vw, 3.2rem); margin-bottom: 0.8rem; }
  .sec-head p { color: var(--c-muted); max-width: 520px; margin: 0 auto; font-size: 1rem; }

  /* Divider vonal */
  .divider {
    width: 48px; height: 1px;
    background: var(--c-gold); margin: 1.5rem auto;
  }

  /* Footer */
  .site-footer {
    background: var(--c-ink); color: rgba(255,255,255,0.55);
    text-align: center; padding: 3.5rem 2rem;
  }
  .ft-quote {
    font-family: var(--f-serif); font-style: italic;
    font-size: 1.25rem; color: rgba(255,255,255,0.85);
    margin-bottom: 0.75rem;
  }
  .ft-copy { font-size: 0.75rem; letter-spacing: 0.05em; }

  /* ── MOBIL ───────────────────────────── */
  @media (max-width: 768px) {
    .nav-wrap { padding: 0.8rem 1.25rem; gap: 1rem; }
    nav { display: none; }
    .nav-end { gap: 0.75rem; }
    .lbtn { padding: 0.25rem 0.3rem; font-size: 0.65rem; }
    .cta-pill { padding: 0.6rem 1.2rem; font-size: 0.72rem; }
    .sec { padding: clamp(3rem, 8vw, 5rem) 1.25rem; }
  }
</style>
