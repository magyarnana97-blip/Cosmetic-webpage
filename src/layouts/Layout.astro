---
// src/layouts/Layout.astro
import type { Locale } from '../i18n/utils';
import { getSection, localePath, SUPPORTED_LOCALES } from '../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description: string;
}

const { locale, title, description } = Astro.props;
const nav = getSection<any>(locale, 'nav');
const lang_labels = getSection<any>(locale, 'lang');
const footer = getSection<any>(locale, 'footer');

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BeautySalon",
  "name": "Hancz Marianna Szépségterapeuta",
  "url": "https://szepsegterapeuta.hu",
  "telephone": "+36-20-339-3399",
  "email": "info@szepsegterapeuta.hu",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Dolgos utca 2. 6B lépcsőház",
    "addressLocality": "Budapest",
    "postalCode": "1126",
    "addressCountry": "HU"
  },
  "openingHours": "Mo-Su 06:00-20:00",
  "priceRange": "$$",
  "description": description,
  "sameAs": ["https://www.facebook.com/szepsegterapeuta"]
});
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="canonical" href={`https://szepsegterapeuta.hu${localePath(locale)}`} />
  {SUPPORTED_LOCALES.filter(l => l !== 'ja' && l !== 'ko').map(l => (
    <link rel="alternate" hreflang={l} href={`https://szepsegterapeuta.hu${localePath(l)}`} />
  ))}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={schema} />
</head>
<body>
  <header class="nav-header">
    <div class="nav-container">
      <a href={localePath(locale)} class="nav-logo" aria-label="Főoldal">
        <img src="/logo.svg" alt="Szépségterapeuta logó" width="180" height="48" />
      </a>
      <nav aria-label="Főnavigáció">
        <ul class="nav-links">
          <li><a href={`${localePath(locale)}#services`}>{nav.services}</a></li>
          <li><a href={`${localePath(locale)}#about`}>{nav.about}</a></li>
          <li><a href={`${localePath(locale)}#contact`}>{nav.contact}</a></li>
        </ul>
      </nav>
      <div class="nav-right">
        <div class="lang-switcher" role="navigation" aria-label="Nyelvváltó">
          {SUPPORTED_LOCALES.map(l => (
            <a href={localePath(l)} class={`lang-btn ${l === locale ? 'active' : ''}`} hreflang={l} aria-current={l === locale ? 'true' : undefined}>
              {lang_labels[l]}
            </a>
          ))}
        </div>
        <a href={`${localePath(locale)}#contact`} class="btn-primary nav-cta">{nav.book}</a>
      </div>
    </div>
  </header>
  <main id="main-content"><slot /></main>
  <footer class="site-footer">
    <p class="footer-tagline">{footer.tagline}</p>
    <p class="footer-copy">{footer.copyright}</p>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --color-green:      #A8C96A;
    --color-sage:       #6E8467;
    --color-cream:      #FAF9F6;
    --color-beige:      #EDE5D6;
    --color-gray:       #F2F2F2;
    --color-text:       #2C2C2C;
    --color-text-light: #6B6B6B;
    --font-heading:     'Playfair Display', Georgia, serif;
    --font-body:        'Lato', system-ui, sans-serif;
    --max-width:        1200px;
    --section-pad:      clamp(4rem, 8vw, 8rem) 1.5rem;
    --radius:           12px;
    --transition:       0.3s ease;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--font-body); background: var(--color-cream); color: var(--color-text); line-height: 1.7; -webkit-font-smoothing: antialiased; }
  h1, h2, h3 { font-family: var(--font-heading); line-height: 1.25; }
  img { max-width: 100%; height: auto; display: block; }
  .nav-header { position: sticky; top: 0; z-index: 100; background: rgba(250,249,246,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(168,201,106,0.2); }
  .nav-container { max-width: var(--max-width); margin: 0 auto; padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .nav-links { list-style: none; display: flex; gap: 2rem; }
  .nav-links a { text-decoration: none; color: var(--color-text); font-size: 0.95rem; letter-spacing: 0.02em; transition: color var(--transition); }
  .nav-links a:hover { color: var(--color-sage); }
  .nav-right { display: flex; align-items: center; gap: 1rem; }
  .lang-switcher { display: flex; gap: 0.4rem; }
  .lang-btn { font-size: 0.75rem; font-family: var(--font-body); font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; text-decoration: none; color: var(--color-text-light); padding: 0.25rem 0.5rem; border-radius: 4px; transition: all var(--transition); }
  .lang-btn:hover, .lang-btn.active { color: var(--color-sage); background: rgba(110,132,103,0.1); }
  .lang-btn.active { font-weight: 700; }
  .btn-primary { display: inline-block; text-decoration: none; background: var(--color-green); color: #fff; padding: 0.75rem 1.75rem; border-radius: 50px; font-weight: 700; font-size: 0.9rem; letter-spacing: 0.04em; transition: background var(--transition), transform var(--transition); border: none; cursor: pointer; }
  .btn-primary:hover { background: var(--color-sage); transform: translateY(-1px); }
  .btn-outline { display: inline-block; text-decoration: none; background: transparent; color: var(--color-sage); padding: 0.75rem 1.75rem; border-radius: 50px; font-weight: 700; font-size: 0.9rem; letter-spacing: 0.04em; border: 2px solid var(--color-sage); transition: all var(--transition); }
  .btn-outline:hover { background: var(--color-sage); color: #fff; transform: translateY(-1px); }
  .section-label { display: inline-block; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-sage); margin-bottom: 0.75rem; }
  .site-footer { background: var(--color-beige); text-align: center; padding: 3rem 1.5rem; border-top: 1px solid rgba(110,132,103,0.2); }
  .footer-tagline { font-family: var(--font-heading); font-style: italic; font-size: 1.2rem; color: var(--color-sage); margin-bottom: 0.5rem; }
  .footer-copy { font-size: 0.8rem; color: var(--color-text-light); }
  .section { padding: var(--section-pad); }
  .section-inner { max-width: var(--max-width); margin: 0 auto; }
  .section-header { text-align: center; margin-bottom: 3.5rem; }
  .section-header h2 { font-size: clamp(1.8rem, 4vw, 2.8rem); color: var(--color-text); margin-bottom: 1rem; }
  .section-header p { color: var(--color-text-light); max-width: 600px; margin: 0 auto; font-size: 1.05rem; }
  @media (max-width: 768px) { .nav-links { display: none; } .lang-switcher .lang-btn { font-size: 0.7rem; padding: 0.2rem 0.35rem; } }
</style>